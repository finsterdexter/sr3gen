<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels"
             xmlns:vmt="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:tabs="using:SR3Generator.Avalonia.Views.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="850"
             x:Class="SR3Generator.Avalonia.Views.CharacterShellView"
             x:DataType="vm:CharacterShellViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.sidebar-stat">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource InkSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.sidebar-value">
            <Setter Property="FontFamily" Value="JetBrains Mono, monospace"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Top resource bar -->
        <Border Grid.Row="0"
                Background="{StaticResource Surface100Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                <!-- Identity -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Static res:Strings.LabelRace}" Classes="micro-label"/>
                        <TextBlock Text="{Binding SelectedRace}" FontWeight="SemiBold" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Static res:Strings.LabelAspect}" Classes="micro-label"/>
                        <TextBlock Text="{Binding SelectedMagicAspect}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource AccentManaBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="{StaticResource BorderSubtleBrush}" Margin="20,2"/>

                <!-- Resource pools -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Static res:Strings.LabelAttributeShort}" Classes="micro-label"/>
                        <TextBlock Classes="stat-value">
                            <Run Text="{Binding AttributePointsRemaining}"
                                 Foreground="{StaticResource AccentCyberBrush}"/>
                            <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                            <Run Text="{Binding AttributePointsAllowance}"
                                 Foreground="{StaticResource InkSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Static res:Strings.LabelSkillShort}" Classes="micro-label"/>
                        <TextBlock Classes="stat-value">
                            <Run Text="{Binding SkillPointsRemaining}"
                                 Foreground="{StaticResource AccentCyberBrush}"/>
                            <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                            <Run Text="{Binding SkillPointsAllowance}"
                                 Foreground="{StaticResource InkSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasMagic}">
                        <TextBlock Text="{x:Static res:Strings.LabelSpellShort}" Classes="micro-label"/>
                        <TextBlock Classes="stat-value">
                            <Run Text="{Binding SpellPointsRemaining}"
                                 Foreground="{StaticResource AccentManaBrush}"/>
                            <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                            <Run Text="{Binding SpellPointsAllowance}"
                                 Foreground="{StaticResource InkSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="4" Width="1" Background="{StaticResource BorderSubtleBrush}" Margin="20,2"/>

                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{x:Static res:Strings.LabelNuyen}" Classes="micro-label"/>
                    <TextBlock Text="{Binding NuyenRemaining, StringFormat='{}{0:N0}¥'}"
                               Classes="stat-value"
                               Foreground="{StaticResource AccentNuyenBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,240">
            <TabControl Grid.Column="0"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Margin="8,8,0,8"
                        Padding="0">
                <TabItem Header="{x:Static res:Strings.TabPriorities}">
                    <tabs:PrioritiesView DataContext="{Binding PrioritiesVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabRace}">
                    <tabs:RaceView DataContext="{Binding RaceVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabMagic}" IsVisible="{Binding CanChooseMagic}">
                    <tabs:MagicContainerView DataContext="{Binding MagicContainerVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabAttributes}">
                    <tabs:AttributesView DataContext="{Binding AttributesVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabSkills}">
                    <tabs:SkillsView DataContext="{Binding SkillsVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabGear}">
                    <tabs:GearView DataContext="{Binding GearVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabAugments}">
                    <tabs:AugmentationsView DataContext="{Binding AugmentationsVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabContacts}">
                    <tabs:ContactsView DataContext="{Binding ContactsVM}"/>
                </TabItem>
                <TabItem Header="{x:Static res:Strings.TabSummary}">
                    <tabs:SummaryView DataContext="{Binding SummaryVM}"/>
                </TabItem>
            </TabControl>

            <!-- Right sidebar - compact live summary -->
            <Border Grid.Column="1"
                    Background="{StaticResource Surface100Brush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{x:Static res:Strings.SectionQuickView}" Classes="section-header"/>

                        <!-- Attributes -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.SectionAttributes}" Classes="micro-label"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16" RowSpacing="3"
                                  RowDefinitions="Auto,Auto,Auto">
                                <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{x:Static res:Strings.AbbrBody}" Classes="sidebar-stat"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryVM.BodyDisplay}" Classes="sidebar-value"/>
                                </Grid>
                                <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{x:Static res:Strings.AbbrQuickness}" Classes="sidebar-stat"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryVM.QuicknessDisplay}" Classes="sidebar-value"/>
                                </Grid>
                                <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{x:Static res:Strings.AbbrStrength}" Classes="sidebar-stat"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryVM.StrengthDisplay}" Classes="sidebar-value"/>
                                </Grid>
                                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{x:Static res:Strings.AbbrCharisma}" Classes="sidebar-stat"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryVM.CharismaDisplay}" Classes="sidebar-value"/>
                                </Grid>
                                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{x:Static res:Strings.AbbrIntelligence}" Classes="sidebar-stat"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryVM.IntelligenceDisplay}" Classes="sidebar-value"/>
                                </Grid>
                                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{x:Static res:Strings.AbbrWillpower}" Classes="sidebar-stat"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryVM.WillpowerDisplay}" Classes="sidebar-value"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}"/>

                        <!-- Derived -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.SectionDerived}" Classes="micro-label"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.AttrReaction}" Classes="sidebar-stat"/>
                                <TextBlock Grid.Column="1" Text="{Binding SummaryVM.ReactionDisplay}" Classes="sidebar-value"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.AttrInitiative}" Classes="sidebar-stat"/>
                                <TextBlock Grid.Column="1" Text="{Binding SummaryVM.InitiativeDisplay}" Classes="sidebar-value"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.AttrEssence}" Classes="sidebar-stat"/>
                                <TextBlock Grid.Column="1" Text="{Binding SummaryVM.EssenceDisplay}" Classes="sidebar-value"
                                           Foreground="{StaticResource AccentCyberBrush}"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasMagic}">
                                <TextBlock Text="{x:Static res:Strings.AttrMagic}" Classes="sidebar-stat"/>
                                <TextBlock Grid.Column="1" Text="{Binding SummaryVM.Magic}" Classes="sidebar-value"
                                           Foreground="{StaticResource AccentManaBrush}"/>
                            </Grid>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}"/>

                        <!-- Status -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.LabelStatus}" Classes="micro-label"/>
                            <Border Background="#1522c55e"
                                    BorderBrush="#3022c55e"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="8,6"
                                    IsVisible="{Binding SummaryVM.IsValid}">
                                <TextBlock Text="{x:Static res:Strings.SummaryReadyToFinalize}"
                                           FontSize="10"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </Border>
                            <ItemsControl ItemsSource="{Binding SummaryVM.ValidationIssues}"
                                          IsVisible="{Binding !SummaryVM.IsValid}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vmt:ValidationIssueItem">
                                        <Border Margin="0,0,0,4"
                                                Background="#15ef4444"
                                                BorderBrush="#30ef4444"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="8,6">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Severity}"
                                                           FontSize="9" FontWeight="SemiBold"
                                                           LetterSpacing="0.5"
                                                           Foreground="{StaticResource DestructiveBrush}"/>
                                                <TextBlock Text="{Binding Message}"
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource InkPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
