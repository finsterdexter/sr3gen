<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SR3Generator.Avalonia.ViewModels"
        x:Class="SR3Generator.Avalonia.Views.OptionsDialog"
        x:DataType="vm:OptionsDialogViewModel"
        Width="520" Height="560"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface100Brush}"
        Title="Options">
    <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
        <DockPanel LastChildFill="True" Margin="20">
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
                <TextBlock Text="Source Books"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource InkPrimaryBrush}"/>
                <TextBlock Text="Uncheck a book to exclude its items from add/buy pickers. Characters already holding items from a disabled source will show a validation warning."
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource InkSecondaryBrush}"/>
            </StackPanel>

            <!-- Footer (OK/Cancel) -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button x:Name="CancelButton" Classes="default" Content="Cancel" Click="OnCancel"/>
                <Button x:Name="OkButton" Classes="primary" Content="OK" Click="OnOk" IsDefault="True"/>
            </StackPanel>

            <!-- Book list -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="4">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Books}" Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:BookOptionItem">
                                <Border Padding="8,4">
                                    <CheckBox IsChecked="{Binding IsChecked}"
                                              IsEnabled="{Binding !IsLocked}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource InkPrimaryBrush}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding Abbreviation}"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       FontSize="10"
                                                       FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Border>
</Window>
