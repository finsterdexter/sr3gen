<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.AdeptPowersView"
             x:DataType="vm:AdeptPowersViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="12">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,8">
            <TextBlock Text="Adept Powers" Classes="page-title"/>
            <TextBlock Text="Physical Adepts channel magic into physical and mental enhancement."
                       FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
        </StackPanel>

        <!-- Power Points Summary -->
        <Border Grid.Row="1" Classes="panel" Padding="8" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="MAGIC" FontSize="9" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MagicRating}" FontWeight="Bold"
                               FontFamily="JetBrains Mono, monospace"
                               Foreground="{StaticResource AccentManaBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="16,0">
                    <TextBlock Text="SPENT" FontSize="9" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PowerPointsSpentDisplay}" FontWeight="Bold"
                               FontFamily="JetBrains Mono, monospace"
                               Foreground="{StaticResource AccentNuyenBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="REMAINING" FontSize="9" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PowerPointsRemainingDisplay}" FontWeight="Bold"
                               FontFamily="JetBrains Mono, monospace"
                               Foreground="{StaticResource AccentKarmaBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,220">
            <!-- Available Powers -->
            <Border Grid.Column="0" Classes="panel" Margin="0,0,6,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="AVAILABLE POWERS" Classes="section-header"/>
                        <TextBox Text="{Binding FilterText}" Watermark="Search powers..."/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Level:" FontSize="10" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AvailableLevels}"
                                      SelectedItem="{Binding SelectedLevel}" MinWidth="60"/>
                            <TextBlock Text="(for leveled powers *)" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding AvailablePowers}"
                             SelectedItem="{Binding SelectedAvailablePower}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:AdeptPowerItem">
                                <Grid ColumnDefinitions="*,50">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="10" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding LeveledIndicator}" FontSize="10"
                                                       Foreground="{StaticResource AccentNuyenBrush}" Margin="2,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Notes}" FontSize="9"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               FontFamily="JetBrains Mono, monospace" FontSize="10"
                                               Foreground="{StaticResource AccentManaBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Add/Remove Controls -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6" Margin="6,0">
                <Button Content="Add" Command="{Binding AddPowerCommand}" Width="60"/>
                <Button Content="Remove" Command="{Binding RemovePowerCommand}" Width="60"/>
            </StackPanel>

            <!-- Purchased Powers -->
            <Border Grid.Column="2" Classes="panel" Margin="6,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PURCHASED" Classes="section-header" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding PurchasedPowers}"
                             SelectedItem="{Binding SelectedPurchasedPower}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:PurchasedPowerItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LevelDisplay}" FontSize="9"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   IsVisible="{Binding LevelDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               FontFamily="JetBrains Mono, monospace" FontSize="10"
                                               Foreground="{StaticResource AccentManaBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
