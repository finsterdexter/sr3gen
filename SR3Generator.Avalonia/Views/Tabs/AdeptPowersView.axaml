<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.AdeptPowersView"
             x:DataType="vm:AdeptPowersViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="Adept Powers" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Physical Adepts channel magic internally to enhance their physical and mental abilities."
                       TextWrapping="Wrap" Foreground="Gray"/>
        </StackPanel>

        <!-- Power Points Summary -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Magic Rating:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MagicRating}" FontWeight="Bold" Foreground="Violet" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="32,0">
                    <TextBlock Text="Power Points Spent: " VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PowerPointsSpentDisplay}" FontWeight="Bold" Foreground="Orange" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Remaining: " VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PowerPointsRemainingDisplay}" FontWeight="Bold" Foreground="LimeGreen" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,280">
            <!-- Available Powers -->
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
                        <TextBlock Text="Available Powers" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding FilterText}" Watermark="Search powers..." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Level:" VerticalAlignment="Center" Foreground="Gray"/>
                            <ComboBox ItemsSource="{Binding AvailableLevels}"
                                      SelectedItem="{Binding SelectedLevel}"
                                      MinWidth="60"/>
                            <TextBlock Text="(for leveled powers marked with *)"
                                       Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding AvailablePowers}"
                             SelectedItem="{Binding SelectedAvailablePower}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:AdeptPowerItem">
                                <Grid ColumnDefinitions="*,60" Margin="0,2">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding LeveledIndicator}" Foreground="Orange" Margin="2,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Notes}" Foreground="Gray" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               Foreground="Cyan" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Add/Remove Controls -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="12" Margin="12,0">
                <Button Content="Add" Command="{Binding AddPowerCommand}" Width="70"/>
                <Button Content="Remove" Command="{Binding RemovePowerCommand}" Width="70"/>
            </StackPanel>

            <!-- Purchased Powers -->
            <Border Grid.Column="2" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Purchased Powers" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding PurchasedPowers}"
                             SelectedItem="{Binding SelectedPurchasedPower}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:PurchasedPowerItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LevelDisplay}" Foreground="Gray" FontSize="11"
                                                   IsVisible="{Binding LevelDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               Foreground="Cyan" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
