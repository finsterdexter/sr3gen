<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.AdeptPowersView"
             x:DataType="vm:AdeptPowersViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.AdeptPowersTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.AdeptPowersSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="28">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelMagic}" Classes="micro-label"/>
                    <TextBlock Text="{Binding MagicRating}" Classes="stat-value-lg"
                               Foreground="{StaticResource AccentManaBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelPowerPtsRemaining}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value-lg">
                        <Run Text="{Binding PowerPointsRemainingDisplay}"
                             Foreground="{StaticResource AccentKarmaBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding MagicRating}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelSpent}" Classes="micro-label"/>
                    <TextBlock Text="{Binding PowerPointsSpentDisplay}" Classes="stat-value"
                               Foreground="{StaticResource InkSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="2" Classes="resource-bar" Margin="0,0,0,12">
            <TextBox Text="{Binding FilterText}"
                     Watermark="{x:Static res:Strings.WatermarkSearchPowers}"
                     MinWidth="240"
                     HorizontalAlignment="Left"/>
        </Border>

        <!-- Detail 20% | Available 50% | Purchased 30% -->
        <Grid Grid.Row="3" ColumnDefinitions="2*,12,5*,12,3*">
            <!-- Detail -->
            <Border Grid.Column="0" Classes="panel">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="DETAIL" Classes="section-header"/>
                    <ScrollViewer>
                        <Grid>
                            <TextBlock Text="Select a power to see details."
                                       Classes="body" TextWrapping="Wrap"
                                       Foreground="{StaticResource InkMutedBrush}">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="SelectedAvailablePower" Converter="{x:Static ObjectConverters.IsNull}"/>
                                        <Binding Path="SelectedPurchasedPower" Converter="{x:Static ObjectConverters.IsNull}"/>
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>

                            <!-- Purchased power detail (Remove action) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding SelectedPurchasedPower, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding SelectedPurchasedPower.DisplayName}"
                                           FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                                      RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="LEVEL" Classes="micro-label"
                                               IsVisible="{Binding SelectedPurchasedPower.IsLeveled}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPurchasedPower.Level}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentManaBrush}"
                                               IsVisible="{Binding SelectedPurchasedPower.IsLeveled}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="COST" Classes="micro-label"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPurchasedPower.CostDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentManaBrush}"/>
                                </Grid>

                                <StackPanel Spacing="2"
                                            IsVisible="{Binding SelectedPurchasedPower.Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="NOTES" Classes="micro-label"/>
                                    <TextBlock Text="{Binding SelectedPurchasedPower.Notes}"
                                               Classes="body" TextWrapping="Wrap"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedPurchasedPower.BookPageDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           IsVisible="{Binding SelectedPurchasedPower.BookPageDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,4"/>

                                <Button Content="{x:Static res:Strings.ButtonRemove}"
                                        Classes="action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding RemovePowerCommand}"/>
                            </StackPanel>

                            <!-- Available power detail (Add action with optional Level picker) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding SelectedAvailablePower, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding SelectedAvailablePower.DisplayName}"
                                               FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="*" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentNuyenBrush}"
                                               IsVisible="{Binding SelectedAvailablePower.IsLeveled}"
                                               ToolTip.Tip="Leveled power"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                                      RowDefinitions="Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="COST / LEVEL" Classes="micro-label"
                                               IsVisible="{Binding SelectedAvailablePower.IsLeveled}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="COST" Classes="micro-label"
                                               IsVisible="{Binding !SelectedAvailablePower.IsLeveled}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAvailablePower.CostDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentManaBrush}"/>
                                </Grid>

                                <!-- Level picker for leveled powers -->
                                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center"
                                      IsVisible="{Binding SelectedAvailablePower.IsLeveled}">
                                    <TextBlock Text="{x:Static res:Strings.LabelLevel}" Classes="micro-label"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableLevels}"
                                              SelectedItem="{Binding SelectedLevel}"
                                              MinWidth="80"/>
                                </Grid>

                                <StackPanel Spacing="2"
                                            IsVisible="{Binding SelectedAvailablePower.Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="NOTES" Classes="micro-label"/>
                                    <TextBlock Text="{Binding SelectedAvailablePower.Notes}"
                                               Classes="body" TextWrapping="Wrap"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedAvailablePower.BookPageDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           IsVisible="{Binding SelectedAvailablePower.BookPageDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <Button Content="{x:Static res:Strings.ButtonAddPower}"
                                        Classes="primary action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding AddPowerCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Available -->
            <Border Grid.Column="2" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionAvailable}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox Name="AvailableList"
                             ItemsSource="{Binding AvailablePowers}"
                             SelectedItem="{Binding SelectedAvailablePower}"
                             DoubleTapped="OnAvailableListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:AdeptPowerItem">
                                <Grid ColumnDefinitions="*,60">
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Classes="body" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding LeveledIndicator}" Classes="body"
                                                       Foreground="{StaticResource AccentNuyenBrush}"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Notes}" FontSize="10"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               Classes="stat-value"
                                               Foreground="{StaticResource AccentManaBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Purchased -->
            <Border Grid.Column="4" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionPurchased}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox Name="PurchasedList"
                             ItemsSource="{Binding PurchasedPowers}"
                             SelectedItem="{Binding SelectedPurchasedPower}"
                             DoubleTapped="OnPurchasedListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:PurchasedPowerItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Classes="body" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LevelDisplay}" FontSize="10"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   IsVisible="{Binding LevelDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               Classes="stat-value"
                                               Foreground="{StaticResource AccentManaBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
