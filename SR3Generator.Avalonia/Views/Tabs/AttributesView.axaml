<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.AttributesView"
             x:DataType="vm:AttributesViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.attr-header">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
            <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12" MaxWidth="900" HorizontalAlignment="Left">
            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Static res:Strings.AttributesTitle}" Classes="page-title"/>
                <TextBlock Classes="page-subtitle"
                           Text="{x:Static res:Strings.AttributesSubtitle}"/>
            </StackPanel>

            <!-- Points resource bar -->
            <Border Classes="resource-bar">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{x:Static res:Strings.LabelAttributePoints}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value-lg">
                        <Run Text="{Binding PointsRemaining}"
                             Foreground="{StaticResource AccentCyberBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding PointsAllowance}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Physical & Mental -->
            <Grid ColumnDefinitions="*,12,*">
                <!-- Physical -->
                <Border Grid.Column="0" Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Static res:Strings.SectionPhysical}" Classes="section-header"/>
                        <Grid ColumnDefinitions="*,100,40,80">
                            <TextBlock Grid.Column="1" Text="{x:Static res:Strings.HeaderBase}" Classes="attr-header"/>
                            <TextBlock Grid.Column="2" Text="{x:Static res:Strings.HeaderMod}" Classes="attr-header"/>
                            <TextBlock Grid.Column="3" Text="{x:Static res:Strings.HeaderTotal}" Classes="attr-header"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,100,40,80" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <!-- Body -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.AttrBody}" VerticalAlignment="Center" Classes="body"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1" Classes="prominent"
                                           Value="{Binding BodyValue}"
                                           Minimum="1" Maximum="6"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding BodyRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Classes="data" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3"
                                       Text="{Binding BodyDisplay}"
                                       HorizontalAlignment="Center"
                                       Classes="stat-value-lg"/>

                            <!-- Quickness -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.AttrQuickness}" VerticalAlignment="Center" Classes="body"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Classes="prominent"
                                           Value="{Binding QuicknessValue}"
                                           Minimum="1" Maximum="6"/>
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="{Binding QuicknessRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Classes="data" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3"
                                       Text="{Binding QuicknessDisplay}"
                                       HorizontalAlignment="Center"
                                       Classes="stat-value-lg"/>

                            <!-- Strength -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.AttrStrength}" VerticalAlignment="Center" Classes="body"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Classes="prominent"
                                           Value="{Binding StrengthValue}"
                                           Minimum="1" Maximum="6"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding StrengthRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Classes="data" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3"
                                       Text="{Binding StrengthDisplay}"
                                       HorizontalAlignment="Center"
                                       Classes="stat-value-lg"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mental -->
                <Border Grid.Column="2" Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Static res:Strings.SectionMental}" Classes="section-header"/>
                        <Grid ColumnDefinitions="*,100,40,80">
                            <TextBlock Grid.Column="1" Text="{x:Static res:Strings.HeaderBase}" Classes="attr-header"/>
                            <TextBlock Grid.Column="2" Text="{x:Static res:Strings.HeaderMod}" Classes="attr-header"/>
                            <TextBlock Grid.Column="3" Text="{x:Static res:Strings.HeaderTotal}" Classes="attr-header"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,100,40,80" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <!-- Charisma -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.AttrCharisma}" VerticalAlignment="Center" Classes="body"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1" Classes="prominent"
                                           Value="{Binding CharismaValue}"
                                           Minimum="1" Maximum="6"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding CharismaRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Classes="data" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3"
                                       Text="{Binding CharismaDisplay}"
                                       HorizontalAlignment="Center"
                                       Classes="stat-value-lg"/>

                            <!-- Intelligence -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.AttrIntelligence}" VerticalAlignment="Center" Classes="body"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Classes="prominent"
                                           Value="{Binding IntelligenceValue}"
                                           Minimum="1" Maximum="6"/>
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="{Binding IntelligenceRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Classes="data" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3"
                                       Text="{Binding IntelligenceDisplay}"
                                       HorizontalAlignment="Center"
                                       Classes="stat-value-lg"/>

                            <!-- Willpower -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.AttrWillpower}" VerticalAlignment="Center" Classes="body"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Classes="prominent"
                                           Value="{Binding WillpowerValue}"
                                           Minimum="1" Maximum="6"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding WillpowerRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Classes="data" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3"
                                       Text="{Binding WillpowerDisplay}"
                                       HorizontalAlignment="Center"
                                       Classes="stat-value-lg"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Derived Attributes -->
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Static res:Strings.SectionDerived}" Classes="section-header"/>
                <Border Classes="panel-inset" Padding="16,10">
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Left">
                            <TextBlock Text="{x:Static res:Strings.AttrReaction}" Classes="body"
                                       Foreground="{StaticResource InkSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReactionDisplay}" Classes="stat-value-lg"/>
                            <TextBlock Text="{x:Static res:Strings.AttrReactionFormula}" FontSize="10"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.AttrEssence}" Classes="body"
                                       Foreground="{StaticResource InkSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding EssenceDisplay}"
                                       Classes="stat-value-lg"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{x:Static res:Strings.AttrMagic}" Classes="body"
                                       Foreground="{StaticResource InkSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MagicValue}"
                                       Classes="stat-value-lg"
                                       Foreground="{StaticResource AccentManaBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
