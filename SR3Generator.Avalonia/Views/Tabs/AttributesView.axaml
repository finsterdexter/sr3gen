<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.AttributesView"
             x:DataType="vm:AttributesViewModel">

    <ScrollViewer Padding="12">
        <StackPanel Spacing="12">
            <!-- Header with Points -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="Attributes" Classes="page-title"/>
                    <TextBlock Text="Distribute points. Racial modifiers applied automatically."
                               FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
                </StackPanel>

                <!-- Points Counter -->
                <Border Grid.Column="1" Classes="panel" Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="POINTS" Classes="section-header" VerticalAlignment="Center"/>
                        <TextBlock FontFamily="JetBrains Mono, monospace" VerticalAlignment="Center" FontSize="14">
                            <Run Text="{Binding PointsRemaining}" FontWeight="Bold"
                                 Foreground="{StaticResource AccentCyberBrush}"/>
                            <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                            <Run Text="{Binding PointsAllowance}" Foreground="{StaticResource InkSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <!-- Physical Attributes -->
                <Border Grid.Row="0" Grid.Column="0" Classes="panel" Margin="0,0,6,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="PHYSICAL" Classes="section-header"/>

                        <Grid ColumnDefinitions="90,80,50,50" RowDefinitions="Auto,Auto,Auto,Auto">
                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Base" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Mod" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Total" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"/>

                            <!-- Body -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Body" VerticalAlignment="Center" FontSize="11"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                           Value="{Binding BodyValue}"
                                           Minimum="1" Maximum="6"
                                           Width="70" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="{Binding BodyRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="JetBrains Mono, monospace" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3"
                                       Text="{Binding BodyTotal}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"/>

                            <!-- Quickness -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Quickness" VerticalAlignment="Center" FontSize="11"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                           Value="{Binding QuicknessValue}"
                                           Minimum="1" Maximum="6"
                                           Width="70" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding QuicknessRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="JetBrains Mono, monospace" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3"
                                       Text="{Binding QuicknessTotal}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"/>

                            <!-- Strength -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Strength" VerticalAlignment="Center" FontSize="11"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1"
                                           Value="{Binding StrengthValue}"
                                           Minimum="1" Maximum="6"
                                           Width="70" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2"
                                       Text="{Binding StrengthRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="JetBrains Mono, monospace" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="3"
                                       Text="{Binding StrengthTotal}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mental Attributes -->
                <Border Grid.Row="0" Grid.Column="1" Classes="panel" Margin="6,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="MENTAL" Classes="section-header"/>

                        <Grid ColumnDefinitions="90,80,50,50" RowDefinitions="Auto,Auto,Auto,Auto">
                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Base" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Mod" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Total" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"/>

                            <!-- Charisma -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Charisma" VerticalAlignment="Center" FontSize="11"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                           Value="{Binding CharismaValue}"
                                           Minimum="1" Maximum="6"
                                           Width="70" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                       Text="{Binding CharismaRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="JetBrains Mono, monospace" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3"
                                       Text="{Binding CharismaTotal}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"/>

                            <!-- Intelligence -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Intelligence" VerticalAlignment="Center" FontSize="11"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                           Value="{Binding IntelligenceValue}"
                                           Minimum="1" Maximum="6"
                                           Width="70" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding IntelligenceRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="JetBrains Mono, monospace" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3"
                                       Text="{Binding IntelligenceTotal}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"/>

                            <!-- Willpower -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Willpower" VerticalAlignment="Center" FontSize="11"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1"
                                           Value="{Binding WillpowerValue}"
                                           Minimum="1" Maximum="6"
                                           Width="70" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2"
                                       Text="{Binding WillpowerRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontFamily="JetBrains Mono, monospace" FontSize="11"
                                       Foreground="{StaticResource AccentCyberBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="3"
                                       Text="{Binding WillpowerTotal}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Derived Attributes -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Classes="panel-inset" Margin="0,12,0,0">
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Reaction" FontSize="11"
                                       Foreground="{StaticResource InkSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReactionValue}"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="(QCK+INT)/2" FontSize="9"
                                       Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Essence" FontSize="11"
                                       Foreground="{StaticResource InkSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding EssenceDisplay}"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"
                                       Foreground="{StaticResource AccentCyberBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <TextBlock Text="Magic" FontSize="11"
                                       Foreground="{StaticResource InkSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MagicValue}"
                                       FontWeight="Bold" FontFamily="JetBrains Mono, monospace" FontSize="13"
                                       Foreground="{StaticResource AccentManaBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
