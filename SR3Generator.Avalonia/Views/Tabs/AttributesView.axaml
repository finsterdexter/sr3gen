<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.AttributesView"
             x:DataType="vm:AttributesViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">
            <TextBlock Text="Attributes" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Distribute your attribute points among Body, Quickness, Strength, Charisma, Intelligence, and Willpower. Racial modifiers are applied automatically."
                       TextWrapping="Wrap" Foreground="Gray"/>

            <!-- Points Summary -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="Attribute Points" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding PointsSpent, StringFormat='Spent: {0}'}" Margin="16,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding PointsAllowance, StringFormat='/ {0}'}" Foreground="Gray"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding PointsRemaining, StringFormat='Remaining: {0}'}"
                               FontWeight="Bold"
                               Margin="24,0,0,0"/>
                </Grid>
            </Border>

            <!-- Physical Attributes -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="16" Margin="0,8,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Physical Attributes" FontWeight="SemiBold" FontSize="16"/>

                    <Grid ColumnDefinitions="120,100,80,80,80" RowDefinitions="Auto,Auto,Auto,Auto">
                        <!-- Headers -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Attribute" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Base" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Racial" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Total" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>

                        <!-- Body -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Body" VerticalAlignment="Center" Margin="0,8"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding BodyValue}"
                                       Minimum="1" Maximum="6"
                                       Width="80" Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="{Binding BodyRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                   Text="{Binding BodyTotal}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>

                        <!-- Quickness -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Quickness" VerticalAlignment="Center" Margin="0,8"/>
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding QuicknessValue}"
                                       Minimum="1" Maximum="6"
                                       Width="80" Margin="0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="2"
                                   Text="{Binding QuicknessRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   Text="{Binding QuicknessTotal}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>

                        <!-- Strength -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Strength" VerticalAlignment="Center" Margin="0,8"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Value="{Binding StrengthValue}"
                                       Minimum="1" Maximum="6"
                                       Width="80" Margin="0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="2"
                                   Text="{Binding StrengthRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="3"
                                   Text="{Binding StrengthTotal}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Mental Attributes -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Mental Attributes" FontWeight="SemiBold" FontSize="16"/>

                    <Grid ColumnDefinitions="120,100,80,80,80" RowDefinitions="Auto,Auto,Auto,Auto">
                        <!-- Headers -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Attribute" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Base" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Racial" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Total" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>

                        <!-- Charisma -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Charisma" VerticalAlignment="Center" Margin="0,8"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding CharismaValue}"
                                       Minimum="1" Maximum="6"
                                       Width="80" Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="{Binding CharismaRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                   Text="{Binding CharismaTotal}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>

                        <!-- Intelligence -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Intelligence" VerticalAlignment="Center" Margin="0,8"/>
                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                       Value="{Binding IntelligenceValue}"
                                       Minimum="1" Maximum="6"
                                       Width="80" Margin="0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="2"
                                   Text="{Binding IntelligenceRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   Text="{Binding IntelligenceTotal}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>

                        <!-- Willpower -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Willpower" VerticalAlignment="Center" Margin="0,8"/>
                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                       Value="{Binding WillpowerValue}"
                                       Minimum="1" Maximum="6"
                                       Width="80" Margin="0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="2"
                                   Text="{Binding WillpowerRacialMod, StringFormat='{}{0:+#;-#;0}'}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="3"
                                   Text="{Binding WillpowerTotal}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Derived Attributes -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Derived Attributes" FontWeight="SemiBold" FontSize="16"/>

                    <Grid ColumnDefinitions="120,80,*" RowDefinitions="Auto,Auto,Auto">
                        <!-- Reaction -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Reaction" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding ReactionValue}"
                                   FontWeight="Bold" FontSize="16"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="(Quickness + Intelligence) / 2"
                                   Foreground="Gray" FontSize="12" VerticalAlignment="Center"/>

                        <!-- Essence -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Essence" VerticalAlignment="Center" Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding EssenceDisplay}"
                                   FontWeight="Bold" FontSize="16" Margin="0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="Reduced by cyberware"
                                   Foreground="Gray" FontSize="12" VerticalAlignment="Center" Margin="0,8"/>

                        <!-- Magic -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Magic" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding MagicValue}"
                                   FontWeight="Bold" FontSize="16"/>
                        <TextBlock Grid.Row="2" Grid.Column="2"
                                   Text="Equal to Essence for magical characters"
                                   Foreground="Gray" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
