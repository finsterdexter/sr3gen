<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.ContactsView"
             x:DataType="vm:ContactsViewModel">

    <Grid RowDefinitions="Auto,*" Margin="12">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,12">
            <TextBlock Text="Contacts" Classes="page-title"/>
            <TextBlock Text="2 free Level 1 contacts. Additional contacts cost nuyen."
                       FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <!-- Left: Add Contacts -->
            <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,6,0">
                <!-- Free Contacts -->
                <Border Classes="panel">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="FREE CONTACTS" Classes="section-header"/>
                            <TextBlock Grid.Column="1" FontSize="10" Foreground="{StaticResource InkSecondaryBrush}">
                                <Run Text="{Binding FreeContactsUsed}"/>
                                <Run Text=" / 2"/>
                            </TextBlock>
                        </Grid>
                        <TextBlock Text="Level 1 contacts only." FontSize="10"
                                   Foreground="{StaticResource InkMutedBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding NewContactName}" Watermark="Contact name..." Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Add Free" Command="{Binding AddFreeContactCommand}" Classes="compact"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Purchase Contacts -->
                <Border Classes="panel">
                    <StackPanel Spacing="8">
                        <TextBlock Text="BUY CONTACTS" Classes="section-header"/>

                        <!-- Level Reference -->
                        <Border Classes="panel-inset">
                            <Grid ColumnDefinitions="60,*,80" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Lvl 1" FontSize="10"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Contact" FontSize="10" Foreground="{StaticResource InkSecondaryBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="5,000¥" FontSize="10"
                                           FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Lvl 2" FontSize="10" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Buddy" FontSize="10" Foreground="{StaticResource InkSecondaryBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="10,000¥" FontSize="10"
                                           FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Lvl 3" FontSize="10" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Friend for Life" FontSize="10" Foreground="{StaticResource InkSecondaryBrush}" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="200,000¥" FontSize="10"
                                           FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,100,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewContactName}" Watermark="Contact name..." Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableLevels}"
                                      SelectedItem="{Binding NewContactLevel}" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="Buy" Command="{Binding BuyContactCommand}" Classes="compact"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Contact List -->
            <Border Grid.Column="1" Classes="panel" Margin="6,0,0,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Text="YOUR CONTACTS" Classes="section-header"/>
                        <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveContactCommand}" Classes="compact"/>
                    </Grid>

                    <DockPanel DockPanel.Dock="Bottom">
                        <TextBlock Text="{Binding NuyenSpentOnContacts, StringFormat='Spent: {0:N0}¥'}"
                                   FontSize="10" FontFamily="JetBrains Mono, monospace"
                                   Foreground="{StaticResource InkSecondaryBrush}" Margin="0,8,0,0"/>
                    </DockPanel>

                    <ListBox ItemsSource="{Binding Contacts}"
                             SelectedItem="{Binding SelectedContact}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,80,60">
                                    <TextBlock Text="{Binding Name}" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LevelDisplay}"
                                               FontSize="10" Foreground="{StaticResource InkSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}"
                                               FontSize="10" FontFamily="JetBrains Mono, monospace"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentNuyenBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
