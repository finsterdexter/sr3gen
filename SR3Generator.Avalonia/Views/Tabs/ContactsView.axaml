<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.ContactsView"
             x:DataType="vm:ContactsViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.ContactsTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.ContactsSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelFreeContacts}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value">
                        <Run Text="{Binding FreeContactsUsed}"
                             Foreground="{StaticResource AccentKarmaBrush}"/>
                        <Run Text=" / 2" Foreground="{StaticResource InkMutedBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelSpentOnContacts}" Classes="micro-label"/>
                    <TextBlock Text="{Binding NuyenSpentOnContacts, StringFormat='{}{0:N0}¥'}"
                               Classes="stat-value"
                               Foreground="{StaticResource AccentNuyenBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,12,*">
            <!-- Left: Add Contacts -->
            <StackPanel Grid.Column="0" Spacing="12">
                <!-- Free Contacts -->
                <Border Classes="panel">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Static res:Strings.SectionAddFreeContact}" Classes="section-header"/>
                        <TextBlock Text="{x:Static res:Strings.ContactsFreeOnly}"
                                   FontSize="10"
                                   Foreground="{StaticResource InkMutedBrush}"/>
                        <Grid ColumnDefinitions="*,8,Auto">
                            <TextBox Text="{Binding NewContactName}"
                                     Watermark="{x:Static res:Strings.WatermarkContactName}"/>
                            <Button Grid.Column="2" Content="{x:Static res:Strings.ButtonAddFree}"
                                    Classes="primary action"
                                    Command="{Binding AddFreeContactCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Purchase Contacts -->
                <Border Classes="panel">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{x:Static res:Strings.SectionBuyContact}" Classes="section-header"/>

                        <Border Classes="panel-inset" Padding="8,6">
                            <Grid ColumnDefinitions="60,*,90"
                                  RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.ContactsTierLvl1}" Classes="body-sm"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Static res:Strings.ContactsTierContact}" Classes="body-sm"
                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static res:Strings.ContactsCostLvl1}" Classes="data" FontSize="10"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.ContactsTierLvl2}" Classes="body-sm"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Static res:Strings.ContactsTierBuddy}" Classes="body-sm"
                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Static res:Strings.ContactsCostLvl2}" Classes="data" FontSize="10"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.ContactsTierLvl3}" Classes="body-sm"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Static res:Strings.ContactsTierFriendForLife}" Classes="body-sm"
                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Static res:Strings.ContactsCostLvl3}" Classes="data" FontSize="10"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,8,110,8,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewContactName}"
                                     Watermark="{x:Static res:Strings.WatermarkContactName}"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableLevels}"
                                      SelectedItem="{Binding NewContactLevel}"
                                      HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="4" Content="{x:Static res:Strings.ButtonBuy}"
                                    Classes="action"
                                    Command="{Binding BuyContactCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Contact List -->
            <Border Grid.Column="2" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,12,12,8">
                        <TextBlock Text="{x:Static res:Strings.SectionYourContacts}" Classes="section-header"/>
                        <Button Grid.Column="1" Content="{x:Static res:Strings.ButtonRemove}"
                                Classes="compact"
                                Command="{Binding RemoveContactCommand}"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding Contacts}"
                             SelectedItem="{Binding SelectedContact}"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,100,80">
                                    <TextBlock Text="{Binding Name}" Classes="body"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LevelDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}"
                                               Classes="data" FontSize="10"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentNuyenBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
