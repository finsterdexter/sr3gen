<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.FociView"
             x:DataType="vm:FociViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="12">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,8">
            <TextBlock Text="Foci" Classes="page-title"/>
            <TextBlock Text="Magical items that enhance abilities. Must be bonded to use."
                       FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
        </StackPanel>

        <!-- Resources Summary -->
        <Border Grid.Row="1" Classes="panel" Padding="8" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <CheckBox Grid.Column="0" Content="Street Index" IsChecked="{Binding UseStreetIndex}" FontSize="10"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="16,0">
                    <TextBlock Text="NUYEN" FontSize="9" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding NuyenRemaining, StringFormat='{}{0:N0}¥'}" FontWeight="Bold"
                               FontFamily="JetBrains Mono, monospace"
                               Foreground="{StaticResource AccentNuyenBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="SPELL PTS" FontSize="9" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SpellPointsRemaining}" FontWeight="Bold"
                               FontFamily="JetBrains Mono, monospace"
                               Foreground="{StaticResource AccentManaBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,240">
            <!-- Available Foci -->
            <Border Grid.Column="0" Classes="panel" Margin="0,0,6,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="AVAILABLE FOCI" Classes="section-header"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding FilterText}" Watermark="Search foci..."/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FocusTypes}"
                                      SelectedItem="{Binding SelectedFocusType}"
                                      MinWidth="120" Margin="8,0,0,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding, TargetNullValue='All Types'}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding AvailableFoci}"
                             SelectedItem="{Binding SelectedAvailableFocus}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:FocusItem">
                                <Grid ColumnDefinitions="*,50,60,50">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding FocusTypeDisplay}" FontSize="9"
                                                   Foreground="{StaticResource InkMutedBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding RatingDisplay}" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}" FontSize="10"
                                               FontFamily="JetBrains Mono, monospace"
                                               Foreground="{StaticResource AccentNuyenBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Availability}" FontSize="9"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Buy/Sell/Bind Controls -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6" Margin="6,0">
                <Button Content="Buy" Command="{Binding BuyFocusCommand}" Width="70"/>
                <Button Content="Sell" Command="{Binding SellFocusCommand}" Width="70"/>
                <Separator Margin="0,8"/>
                <Button Content="Bind" Command="{Binding BindFocusCommand}" Width="70"
                        ToolTip.Tip="Bind using karma"/>
                <Button Content="Bind (SP)" Command="{Binding BindFocusWithSpellPointsCommand}" Width="70"
                        ToolTip.Tip="Bind using spell points"/>
            </StackPanel>

            <!-- Owned Foci -->
            <Border Grid.Column="2" Classes="panel" Margin="6,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="OWNED" Classes="section-header" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding OwnedFoci}"
                             SelectedItem="{Binding SelectedOwnedFocus}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:OwnedFocusItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding FocusTypeDisplay}" FontSize="9"
                                                       Foreground="{StaticResource InkMutedBrush}"/>
                                            <TextBlock Text="{Binding BoundStatus}" FontSize="9"
                                                       Foreground="{StaticResource AccentNuyenBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding BindingCostDisplay}" FontSize="9"
                                               Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
