<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.FociView"
             x:DataType="vm:FociViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.FociTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.FociSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <CheckBox Grid.Column="0" Content="{x:Static res:Strings.CheckStreetIndex}"
                          IsChecked="{Binding UseStreetIndex}"
                          VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="{x:Static res:Strings.LabelNuyen}" Classes="micro-label"/>
                    <TextBlock Text="{Binding NuyenRemaining, StringFormat='{}{0:N0}¥'}"
                               Classes="stat-value-lg"
                               Foreground="{StaticResource AccentNuyenBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelSpellPointsShort}" Classes="micro-label"/>
                    <TextBlock Text="{Binding SpellPointsRemaining}" Classes="stat-value"
                               Foreground="{StaticResource AccentManaBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main: Available | Controls | Owned -->
        <Grid Grid.Row="2" ColumnDefinitions="*,240,12,*">
            <!-- Available -->
            <Border Grid.Column="0" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="12,12,12,8">
                        <TextBlock Text="{x:Static res:Strings.SectionAvailable}" Classes="section-header"/>
                        <Grid ColumnDefinitions="*,8,140">
                            <TextBox Text="{Binding FilterText}" Watermark="{x:Static res:Strings.WatermarkSearchFoci}"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding FocusTypes}"
                                      SelectedItem="{Binding SelectedFocusType}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding, TargetNullValue={x:Static res:Strings.FociTypesAll}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding AvailableFoci}"
                             SelectedItem="{Binding SelectedAvailableFocus}"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:FocusItem">
                                <Grid ColumnDefinitions="*,40,70,40">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Classes="body" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding FocusTypeDisplay}" FontSize="10"
                                                   Foreground="{StaticResource InkMutedBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding RatingDisplay}"
                                               Classes="body-sm"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentNuyenBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Availability}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Controls -->
            <Border Grid.Column="1" Classes="panel" Margin="12,0,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="{x:Static res:Strings.SectionPurchase}" Classes="section-header"/>
                    <Button Content="{x:Static res:Strings.ButtonBuy}"
                            Classes="primary action"
                            HorizontalAlignment="Stretch"
                            Command="{Binding BuyFocusCommand}"/>
                    <Button Content="{x:Static res:Strings.ButtonSell}"
                            Classes="action"
                            HorizontalAlignment="Stretch"
                            Command="{Binding SellFocusCommand}"/>

                    <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,4"/>

                    <TextBlock Text="{x:Static res:Strings.SectionBind}" Classes="section-header"/>
                    <Button Content="{x:Static res:Strings.ButtonBindKarma}"
                            Classes="action"
                            HorizontalAlignment="Stretch"
                            Command="{Binding BindFocusCommand}"
                            ToolTip.Tip="{x:Static res:Strings.TooltipBindKarma}"/>
                    <Button Content="{x:Static res:Strings.ButtonBindSpellPoints}"
                            Classes="action"
                            HorizontalAlignment="Stretch"
                            Command="{Binding BindFocusWithSpellPointsCommand}"
                            ToolTip.Tip="{x:Static res:Strings.TooltipBindSpellPoints}"/>
                </StackPanel>
            </Border>

            <!-- Owned -->
            <Border Grid.Column="3" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionOwned}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox ItemsSource="{Binding OwnedFoci}"
                             SelectedItem="{Binding SelectedOwnedFocus}"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:OwnedFocusItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Classes="body" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding FocusTypeDisplay}" FontSize="10"
                                                       Foreground="{StaticResource InkMutedBrush}"/>
                                            <TextBlock Text="{Binding BoundStatus}" FontSize="10"
                                                       Foreground="{StaticResource AccentNuyenBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding BindingCostDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
