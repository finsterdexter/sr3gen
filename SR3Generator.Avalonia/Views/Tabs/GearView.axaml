<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.GearView"
             x:DataType="vm:GearViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,8">
            <TextBlock Text="Gear &amp; Equipment" Classes="page-title"/>
            <TextBlock Text="Purchase weapons, armor, and equipment with starting nuyen."
                       FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
        </StackPanel>

        <!-- Nuyen Summary -->
        <Border Grid.Row="1" Classes="panel" Padding="8" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="NUYEN" Classes="section-header" VerticalAlignment="Center"/>
                    <CheckBox Content="Street Index (1.5x)" IsChecked="{Binding UseStreetIndex}"
                              FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" FontFamily="JetBrains Mono, monospace" VerticalAlignment="Center">
                    <Run Text="{Binding NuyenRemaining, StringFormat='{}{0:N0}'}" FontWeight="Bold"
                         Foreground="{StaticResource AccentNuyenBrush}"/>
                    <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                    <Run Text="{Binding NuyenAllowance, StringFormat='{}{0:N0}'}"
                         Foreground="{StaticResource InkSecondaryBrush}"/>
                    <Run Text="¥" Foreground="{StaticResource InkMutedBrush}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnDefinitions="160,*,Auto,220">
            <!-- Category Facets -->
            <Border Grid.Column="0" Classes="panel" Margin="0,0,6,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                        <TextBlock Text="CATEGORIES" Classes="section-header"/>
                        <Border Classes="panel-inset" Padding="4">
                            <TextBlock Text="{Binding Breadcrumb}" TextWrapping="Wrap" FontSize="9"
                                       Foreground="{StaticResource InkSecondaryBrush}"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="Up" Command="{Binding NavigateUpCommand}" Classes="compact"/>
                            <Button Content="Clear" Command="{Binding ClearFiltersCommand}" Classes="compact"/>
                        </StackPanel>
                        <TextBox Text="{Binding FilterText}" Watermark="Search..." Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding FilteredCount, StringFormat='{}{0} items'}"
                                   FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                    </StackPanel>

                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding CategoryFacets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:FacetValue">
                                    <Button Padding="4,2" Margin="0,1"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Command="{Binding $parent[UserControl].((vm:GearViewModel)DataContext).SelectCategoryCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Name}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Count, StringFormat='({0})'}"
                                                       FontSize="9" Foreground="{StaticResource InkMutedBrush}" Margin="4,0,0,0"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Gear List -->
            <Border Grid.Column="1" Classes="panel" Margin="0,0,6,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="AVAILABLE" Classes="section-header" Margin="0,0,0,4"/>
                    <ListBox ItemsSource="{Binding FilteredGear}"
                             SelectedItem="{Binding SelectedGearItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,60,60,50">
                                    <TextBlock Text="{Binding Name}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PrimaryStat}"
                                               FontSize="9" Foreground="{StaticResource AccentCyberBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}"
                                               FontSize="9" FontFamily="JetBrains Mono, monospace"
                                               Foreground="{StaticResource AccentNuyenBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Availability}"
                                               FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Buy/Sell Controls -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="6" Margin="0,0,6,0">
                <Button Content="Buy" Command="{Binding BuyGearCommand}" Width="50"/>
                <Button Content="Sell" Command="{Binding SellGearCommand}" Width="50"/>
            </StackPanel>

            <!-- Owned Gear -->
            <Border Grid.Column="3" Classes="panel">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="OWNED" Classes="section-header" Margin="0,0,0,4"/>
                    <ListBox ItemsSource="{Binding OwnedGear}"
                             SelectedItem="{Binding SelectedOwnedGear}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Name}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CostDisplay}"
                                               FontSize="9" FontFamily="JetBrains Mono, monospace"
                                               Foreground="{StaticResource InkMutedBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Selected Item Details -->
        <Border Grid.Row="3" Classes="panel-inset" Margin="0,8,0,0"
                IsVisible="{Binding SelectedGearItem, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid RowDefinitions="Auto,Auto">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding SelectedGearItem.Name}" FontWeight="SemiBold" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedGearItem.CategoryDisplay}"
                                   FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedGearItem.CostDisplay}"
                               FontFamily="JetBrains Mono, monospace"
                               Foreground="{StaticResource AccentNuyenBrush}"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding SelectedGearItem.Availability, StringFormat='Avail {0}'}"
                               FontSize="10" Foreground="{StaticResource InkSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding SelectedGearItem.Concealability, StringFormat='Conceal {0}'}"
                               FontSize="10" Foreground="{StaticResource InkSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedGearItem.Stats}" Margin="0,6,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:StatDisplay">
                            <Border Classes="tag-cyber" Margin="0,0,6,4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Label}" FontSize="9" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Value}" FontSize="9"
                                               Foreground="{StaticResource AccentCyberBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
