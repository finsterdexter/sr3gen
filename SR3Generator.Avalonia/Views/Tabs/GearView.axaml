<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.GearView"
             x:DataType="vm:GearViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.crumb-sep">
            <Setter Property="Text" Value="›"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style Selector="ComboBox.crumb">
            <Setter Property="MinWidth" Value="140"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.GearTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.GearSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <CheckBox Grid.Column="0" Content="{x:Static res:Strings.CheckStreetIndex}"
                          IsChecked="{Binding UseStreetIndex}"
                          VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelNuyen}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value-lg">
                        <Run Text="{Binding NuyenRemaining, StringFormat='{}{0:N0}'}"
                             Foreground="{StaticResource AccentNuyenBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding NuyenAllowance, StringFormat='{}{0:N0}'}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                        <Run Text="¥" Foreground="{StaticResource InkMutedBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Breadcrumb bar -->
        <Border Grid.Row="2" Classes="resource-bar" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                <ItemsControl Grid.Column="0"
                              ItemsSource="{Binding BreadcrumbSteps}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:BreadcrumbStep">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Classes="crumb-sep" IsVisible="{Binding Depth}"/>
                                <ComboBox Classes="crumb"
                                          ItemsSource="{Binding Options}"
                                          SelectedItem="{Binding SelectedValue}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Grid.Column="1" Content="{x:Static res:Strings.ButtonClear}"
                        Classes="compact"
                        Command="{Binding ClearFiltersCommand}"/>
                <TextBox Grid.Column="2"
                         Text="{Binding FilterText}"
                         Watermark="{x:Static res:Strings.WatermarkSearch}"
                         MinWidth="200"/>
            </Grid>
        </Border>

        <!-- Detail 20% | Available 50% | Owned 30% -->
        <Grid Grid.Row="3" ColumnDefinitions="2*,12,5*,12,3*">
            <!-- Detail -->
            <Border Grid.Column="0" Classes="panel">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="DETAIL" Classes="section-header"/>
                    <ScrollViewer>
                        <Grid>
                            <TextBlock Text="Select gear to see details."
                                       Classes="body" TextWrapping="Wrap"
                                       Foreground="{StaticResource InkMutedBrush}">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="SelectedGearItem" Converter="{x:Static ObjectConverters.IsNull}"/>
                                        <Binding Path="SelectedOwnedGear" Converter="{x:Static ObjectConverters.IsNull}"/>
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>

                            <!-- Owned gear detail (Sell action) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding SelectedOwnedGear, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding SelectedOwnedGear.Name}"
                                           FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedOwnedGear.CategoryDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                                      RowDefinitions="Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PAID" Classes="micro-label"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedOwnedGear.PaidCostDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentNuyenBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="AVAIL" Classes="micro-label"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedOwnedGear.Availability}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CONCEAL" Classes="micro-label"
                                               IsVisible="{Binding SelectedOwnedGear.Concealability, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedOwnedGear.Concealability}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               IsVisible="{Binding SelectedOwnedGear.Concealability, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="LEGALITY" Classes="micro-label"
                                               IsVisible="{Binding SelectedOwnedGear.Legality, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedOwnedGear.Legality}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               IsVisible="{Binding SelectedOwnedGear.Legality, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding SelectedOwnedGear.Stats}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:StatDisplay">
                                            <Border Classes="tag-cyber" Margin="0,0,4,4">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Value}" FontSize="10"
                                                               Foreground="{StaticResource AccentCyberBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Spacing="2"
                                            IsVisible="{Binding SelectedOwnedGear.Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="NOTES" Classes="micro-label"/>
                                    <TextBlock Text="{Binding SelectedOwnedGear.Notes}"
                                               Classes="body" TextWrapping="Wrap"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedOwnedGear.BookPageDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           IsVisible="{Binding SelectedOwnedGear.BookPageDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <Button Content="{x:Static res:Strings.ButtonSell}"
                                        Classes="action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding SellGearCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Available gear detail (Buy action) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding SelectedGearItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding SelectedGearItem.Name}"
                                           FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedGearItem.CategoryDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap"/>

                                <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.LabelNuyen}" Classes="micro-label"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGearItem.CostDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentNuyenBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="AVAIL" Classes="micro-label"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGearItem.Availability}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CONCEAL" Classes="micro-label"
                                               IsVisible="{Binding SelectedGearItem.Concealability, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGearItem.Concealability}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               IsVisible="{Binding SelectedGearItem.Concealability, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="LEGALITY" Classes="micro-label"
                                               IsVisible="{Binding SelectedGearItem.Legality, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGearItem.Legality}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               IsVisible="{Binding SelectedGearItem.Legality, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="STREET IDX" Classes="micro-label"
                                               IsVisible="{Binding SelectedGearItem.StreetIndexDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedGearItem.StreetIndexDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               IsVisible="{Binding SelectedGearItem.StreetIndexDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding SelectedGearItem.Stats}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:StatDisplay">
                                            <Border Classes="tag-cyber" Margin="0,0,4,4">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Value}" FontSize="10"
                                                               Foreground="{StaticResource AccentCyberBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Spacing="2"
                                            IsVisible="{Binding SelectedGearItem.Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="NOTES" Classes="micro-label"/>
                                    <TextBlock Text="{Binding SelectedGearItem.Notes}"
                                               Classes="body" TextWrapping="Wrap"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedGearItem.BookPageDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           IsVisible="{Binding SelectedGearItem.BookPageDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <Button Content="{x:Static res:Strings.ButtonBuy}"
                                        Classes="primary action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding BuyGearCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Available -->
            <Border Grid.Column="2" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,12,12,8">
                        <TextBlock Text="{x:Static res:Strings.SectionAvailable}"
                                   Classes="section-header"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding FilteredCount, StringFormat='{}{0} items'}"
                                   FontSize="10"
                                   Foreground="{StaticResource InkMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox Name="AvailableList"
                             ItemsSource="{Binding FilteredGear}"
                             SelectedItem="{Binding SelectedGearItem}"
                             DoubleTapped="OnAvailableListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:GearItem">
                                <Grid ColumnDefinitions="*,60,80,40">
                                    <TextBlock Text="{Binding Name}" Classes="body"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PrimaryStat}"
                                               Classes="body-sm"
                                               Foreground="{StaticResource AccentCyberBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}"
                                               Classes="data" FontSize="10"
                                               Foreground="{StaticResource AccentNuyenBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Availability}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Owned -->
            <Border Grid.Column="4" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionOwned}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox Name="OwnedList"
                             ItemsSource="{Binding OwnedGear}"
                             SelectedItem="{Binding SelectedOwnedGear}"
                             DoubleTapped="OnOwnedListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:OwnedGearItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Name}" Classes="body"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PaidCostDisplay}"
                                               Classes="data" FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
