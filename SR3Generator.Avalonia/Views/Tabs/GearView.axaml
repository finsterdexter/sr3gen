<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.GearView"
             x:DataType="vm:GearViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">
            <TextBlock Text="Gear &amp; Equipment" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Purchase weapons, armor, cyberware, and other equipment with your starting nuyen."
                       TextWrapping="Wrap" Foreground="Gray"/>

            <!-- Nuyen Summary -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Nuyen" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <CheckBox Content="Use Street Index (1.5x cost)" IsChecked="{Binding UseStreetIndex}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding NuyenSpent, StringFormat='Spent: {0:N0}¥'}" Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding NuyenAllowance, StringFormat='/ {0:N0}¥'}" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding NuyenRemaining, StringFormat='Remaining: {0:N0}¥'}"
                               FontWeight="Bold"
                               Margin="24,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Gear Browser and Inventory -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,*">
                    <!-- Available Gear -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                        <TextBlock Text="Available Gear" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding FilterText}" Watermark="Filter gear..." Margin="0,0,0,8"/>
                    </StackPanel>

                    <TreeView Grid.Row="1" Grid.Column="0"
                              ItemsSource="{Binding GearCategories}"
                              SelectedItem="{Binding SelectedGearItem}"
                              MinHeight="350" MaxHeight="450">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Items}">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="IsExpanded" Value="False"/>
                            </Style>
                        </TreeView.Styles>
                    </TreeView>

                    <!-- Buy/Sell Controls -->
                    <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Spacing="12" Margin="16,0">
                        <Button Content="Buy" Command="{Binding BuyGearCommand}" HorizontalAlignment="Stretch"/>
                        <Button Content="Sell" Command="{Binding SellGearCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Owned Gear -->
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Owned Gear" FontWeight="SemiBold"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" Grid.Column="2"
                             ItemsSource="{Binding OwnedGear}"
                             SelectedItem="{Binding SelectedOwnedGear}"
                             MinHeight="350" MaxHeight="450" Margin="0,30,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Category}"
                                               Foreground="Gray" FontSize="12" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CostDisplay}"
                                               Foreground="Gray"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Selected Item Details -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    CornerRadius="8" Padding="12"
                    IsVisible="{Binding SelectedGearItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding SelectedGearItem.Name}"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedGearItem.CostDisplay}"
                               Margin="16,0"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding SelectedGearItem.Availability, StringFormat='Avail: {0}'}"
                               Foreground="Gray" Margin="16,0"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding SelectedGearItem.EssenceDisplay, StringFormat='Essence: {0}'}"
                               Foreground="Gray"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
