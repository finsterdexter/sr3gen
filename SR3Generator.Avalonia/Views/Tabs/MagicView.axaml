<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.MagicView"
             x:DataType="vm:MagicViewModel">

    <ScrollViewer Padding="12">
        <StackPanel Spacing="12">
            <!-- Header -->
            <StackPanel Spacing="2">
                <TextBlock Text="Magic Aspect" Classes="page-title"/>
                <TextBlock Text="Choose magical tradition. Available options depend on Magic priority."
                           FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnDefinitions="200,*">
                <!-- Aspect List -->
                <Border Grid.Column="0" Classes="panel" Margin="0,0,8,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="AVAILABLE ASPECTS" Classes="section-header"/>
                        <ListBox ItemsSource="{Binding AvailableAspects}"
                                 SelectedItem="{Binding SelectedAspect}"
                                 Margin="0,8,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="11"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Aspect Details -->
                <StackPanel Grid.Column="1" Spacing="12">
                    <Border Classes="panel">
                        <StackPanel Spacing="12">
                            <TextBlock Text="ASPECT DETAILS" Classes="section-header"/>
                            <TextBlock Text="{Binding AspectDescription}"
                                       TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource InkSecondaryBrush}"/>

                            <Separator/>

                            <!-- Capabilities Grid -->
                            <Grid ColumnDefinitions="*,80" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sorcery" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding HasSorcery}" FontSize="11"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentManaBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Conjuring" FontSize="11" Margin="0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HasConjuring}" FontSize="11"
                                           HorizontalAlignment="Right" Margin="0,4"
                                           Foreground="{StaticResource AccentManaBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Adept Powers" FontSize="11" Margin="0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HasAdeptPowers}" FontSize="11"
                                           HorizontalAlignment="Right" Margin="0,4"
                                           Foreground="{StaticResource AccentManaBrush}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Starting Spell Points" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StartingSpellPoints}" FontSize="11"
                                           HorizontalAlignment="Right" Margin="0,8,0,4"
                                           FontWeight="Bold" FontFamily="JetBrains Mono, monospace"
                                           Foreground="{StaticResource AccentManaBrush}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Maximum Spell Points" FontSize="11" Margin="0,4"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MaximumSpellPoints}" FontSize="11"
                                           HorizontalAlignment="Right" Margin="0,4"
                                           FontFamily="JetBrains Mono, monospace"
                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Non-magical info -->
                    <Border Background="#15f59e0b"
                            BorderBrush="#30f59e0b"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="10"
                            IsVisible="{Binding !IsMagical}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="!" FontWeight="Bold" FontSize="11"
                                       Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="No magical abilities. Set Magic priority to A or B to gain magic."
                                       TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
