<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.PrioritiesView"
             x:DataType="vm:PrioritiesViewModel">

    <ScrollViewer Padding="12">
        <StackPanel Spacing="12">
            <!-- Header -->
            <StackPanel Spacing="2">
                <TextBlock Text="Priority Selection" Classes="page-title"/>
                <TextBlock Text="Assign A through E. Each priority used once. Selections auto-swap on conflict."
                           FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
            </StackPanel>

            <!-- Priority Matrix - The signature element -->
            <Border Classes="panel">
                <Grid ColumnDefinitions="100,70,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <!-- Headers -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CATEGORY" Classes="section-header"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="RANK" Classes="section-header"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="BENEFIT" Classes="section-header"/>

                    <!-- Race -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Race" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding AvailableRanks}"
                              SelectedItem="{Binding RacePriority}"
                              Width="50" Margin="0,4" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding RaceBenefits}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource InkSecondaryBrush}" Margin="8,6,0,6"/>

                    <!-- Magic -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Magic" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              ItemsSource="{Binding AvailableRanks}"
                              SelectedItem="{Binding MagicPriority}"
                              Width="50" Margin="0,4" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding MagicBenefits}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource AccentManaBrush}" Margin="8,6,0,6"/>

                    <!-- Attributes -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Attributes" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox Grid.Row="3" Grid.Column="1"
                              ItemsSource="{Binding AvailableRanks}"
                              SelectedItem="{Binding AttributesPriority}"
                              Width="50" Margin="0,4" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding AttributesBenefits}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource InkSecondaryBrush}" Margin="8,6,0,6"/>

                    <!-- Skills -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Skills" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox Grid.Row="4" Grid.Column="1"
                              ItemsSource="{Binding AvailableRanks}"
                              SelectedItem="{Binding SkillsPriority}"
                              Width="50" Margin="0,4" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding SkillsBenefits}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource InkSecondaryBrush}" Margin="8,6,0,6"/>

                    <!-- Resources -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Resources" VerticalAlignment="Center" Margin="0,6"/>
                    <ComboBox Grid.Row="5" Grid.Column="1"
                              ItemsSource="{Binding AvailableRanks}"
                              SelectedItem="{Binding ResourcesPriority}"
                              Width="50" Margin="0,4" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding ResourcesBenefits}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource AccentNuyenBrush}" Margin="8,6,0,6"/>
                </Grid>
            </Border>

            <!-- Reference Table - Dense grid -->
            <StackPanel Spacing="4">
                <TextBlock Text="PRIORITY REFERENCE" Classes="section-header"/>
                <Border Classes="panel-inset">
                    <Grid ColumnDefinitions="40,*,*,60,60,80" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <!-- Headers -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Rank" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Race" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Magic" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Attr" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Skill" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Nuyen" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" HorizontalAlignment="Right"/>

                        <!-- A -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="A" FontWeight="Bold"
                                   Foreground="{StaticResource AccentCyberBrush}" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Any" FontSize="10"
                                   Foreground="{StaticResource InkSecondaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Full Magician" FontSize="10"
                                   Foreground="{StaticResource AccentManaBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="30" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="50" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Row="1" Grid.Column="5" Text="1,000,000" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right"
                                   Foreground="{StaticResource AccentNuyenBrush}"/>

                        <!-- B -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" FontWeight="Bold"
                                   Foreground="{StaticResource AccentCyberBrush}" FontSize="11" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Any" FontSize="10"
                                   Foreground="{StaticResource InkSecondaryBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Adept/Aspected" FontSize="10"
                                   Foreground="{StaticResource AccentManaBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="27" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="40" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="5" Text="400,000" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"
                                   Foreground="{StaticResource AccentNuyenBrush}"/>

                        <!-- C -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="C" FontWeight="Bold"
                                   Foreground="{StaticResource AccentCyberBrush}" FontSize="11" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Elf/Troll" FontSize="10"
                                   Foreground="{StaticResource InkSecondaryBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Mundane" FontSize="10"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="3" Text="24" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="4" Text="34" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="5" Text="90,000" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"
                                   Foreground="{StaticResource AccentNuyenBrush}"/>

                        <!-- D -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="D" FontWeight="Bold"
                                   Foreground="{StaticResource AccentCyberBrush}" FontSize="11" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Dwarf/Ork/Human" FontSize="10"
                                   Foreground="{StaticResource InkSecondaryBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Mundane" FontSize="10"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="3" Text="21" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="4" Text="30" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="5" Text="20,000" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"
                                   Foreground="{StaticResource AccentNuyenBrush}"/>

                        <!-- E -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="E" FontWeight="Bold"
                                   Foreground="{StaticResource AccentCyberBrush}" FontSize="11" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Human only" FontSize="10"
                                   Foreground="{StaticResource InkSecondaryBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="Mundane" FontSize="10"
                                   Foreground="{StaticResource InkMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="3" Text="18" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="4" Text="27" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="5" Text="5,000" FontSize="10"
                                   FontFamily="JetBrains Mono, monospace" HorizontalAlignment="Right" Margin="0,2"
                                   Foreground="{StaticResource AccentNuyenBrush}"/>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
