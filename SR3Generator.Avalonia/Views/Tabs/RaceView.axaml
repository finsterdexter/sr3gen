<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.RaceView"
             x:DataType="vm:RaceViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">
            <TextBlock Text="Race Selection" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Choose your character's metatype. Available races depend on your Race priority."
                       TextWrapping="Wrap" Foreground="Gray"/>

            <Grid ColumnDefinitions="300,*" Margin="0,16,0,0">
                <!-- Race List -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                        CornerRadius="8" Padding="8" Margin="0,0,16,0">
                    <ListBox ItemsSource="{Binding AvailableRaces}"
                             SelectedItem="{Binding SelectedRace}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,8" Margin="2">
                                    <TextBlock Text="{Binding Name}" FontSize="16"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Race Details -->
                <StackPanel Grid.Column="1" Spacing="16">
                    <TextBlock Text="{Binding SelectedRace.Name}"
                               FontSize="20" FontWeight="Bold"/>

                    <TextBlock Text="{Binding RaceDescription}"
                               TextWrapping="Wrap"
                               Foreground="Gray"/>

                    <!-- Attribute Modifiers -->
                    <StackPanel Spacing="8" IsVisible="{Binding RacialMods.Count}">
                        <TextBlock Text="Attribute Modifiers" FontWeight="SemiBold" FontSize="16"/>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                CornerRadius="8" Padding="12">
                            <ItemsControl ItemsSource="{Binding RacialMods}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4" Padding="8,4" Margin="0,0,8,8">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding AttributeName}"/>
                                                <TextBlock Text="{Binding ModValue}" FontWeight="Bold"
                                                           Foreground="Green"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- Special Abilities -->
                    <StackPanel Spacing="8" IsVisible="{Binding RacialExtras.Count}">
                        <TextBlock Text="Special Abilities" FontWeight="SemiBold" FontSize="16"/>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                CornerRadius="8" Padding="12">
                            <ItemsControl ItemsSource="{Binding RacialExtras}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                            <TextBlock Text="•" Foreground="Green"/>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
