<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="SR3Generator.Avalonia.Views.Tabs.RaceView"
             x:DataType="vm:RaceViewModel">

    <ScrollViewer Padding="12">
        <StackPanel Spacing="12">
            <!-- Header -->
            <StackPanel Spacing="2">
                <TextBlock Text="Race Selection" Classes="page-title"/>
                <TextBlock Text="Choose metatype. Available races depend on Race priority."
                           FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
            </StackPanel>

            <Grid ColumnDefinitions="200,*">
                <!-- Race List -->
                <Border Grid.Column="0" Classes="panel" Margin="0,0,8,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="AVAILABLE" Classes="section-header"/>
                        <ListBox ItemsSource="{Binding AvailableRaces}"
                                 SelectedItem="{Binding SelectedRace}"
                                 Margin="0,8,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="11"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Race Details -->
                <StackPanel Grid.Column="1" Spacing="12">
                    <!-- Selected Race Header -->
                    <Border Classes="panel">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding SelectedRace.Name}"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding RaceDescription}"
                                       TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource InkSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Attribute Modifiers -->
                    <StackPanel Spacing="4" IsVisible="{Binding RacialMods.Count}">
                        <TextBlock Text="ATTRIBUTE MODIFIERS" Classes="section-header"/>
                        <Border Classes="panel-inset">
                            <ItemsControl ItemsSource="{Binding RacialMods}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="tag-cyber" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding AttributeName}" FontSize="10"/>
                                                <TextBlock Text="{Binding ModValue}" FontWeight="Bold" FontSize="10"
                                                           Foreground="{StaticResource AccentCyberBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- Special Abilities -->
                    <StackPanel Spacing="4" IsVisible="{Binding RacialExtras.Count}">
                        <TextBlock Text="RACIAL ABILITIES" Classes="section-header"/>
                        <Border Classes="panel-inset">
                            <ItemsControl ItemsSource="{Binding RacialExtras}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                                            <TextBlock Text="+" FontSize="10"
                                                       Foreground="{StaticResource AccentKarmaBrush}"/>
                                            <TextBlock Text="{Binding}" FontSize="10"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
