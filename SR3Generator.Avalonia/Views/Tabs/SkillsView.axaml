<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.SkillsView"
             x:DataType="vm:SkillsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.kind-active">
            <Setter Property="Foreground" Value="{StaticResource AccentCyberBrush}"/>
        </Style>
        <Style Selector="TextBlock.kind-knowledge">
            <Setter Property="Foreground" Value="{StaticResource AccentManaBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.SkillsTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.SkillsSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelActive}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value">
                        <Run Text="{Binding ActivePointsRemaining}"
                             Foreground="{StaticResource AccentCyberBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding ActivePointsAllowance}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="{x:Static res:Strings.LabelKnowledge}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value">
                        <Run Text="{Binding KnowledgePointsRemaining}"
                             Foreground="{StaticResource AccentManaBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding KnowledgePointsAllowance}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="2" Classes="resource-bar" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelCategory}" Classes="micro-label"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              MinWidth="200">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:SkillCategory">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Classes.kind-active="{Binding IsActive}"
                                               Classes.kind-knowledge="{Binding IsKnowledge}"/>
                                    <TextBlock Text="{Binding Count, StringFormat='({0})'}"
                                               Foreground="{StaticResource InkMutedBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <TextBox Grid.Column="2"
                         Text="{Binding FilterText}"
                         Watermark="{x:Static res:Strings.WatermarkSearchSkills}"
                         MinWidth="200"
                         HorizontalAlignment="Left"/>
            </Grid>
        </Border>

        <!-- Detail 20% | Available 50% | Purchased 30% -->
        <Grid Grid.Row="3" ColumnDefinitions="2*,12,5*,12,3*">
            <!-- Detail -->
            <Border Grid.Column="0" Classes="panel">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="DETAIL" Classes="section-header"/>
                    <ScrollViewer>
                        <Grid>
                            <!-- Empty state -->
                            <TextBlock Text="Select a skill to see details."
                                       Classes="body" TextWrapping="Wrap"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       IsVisible="{Binding DetailSkill, Converter={x:Static ObjectConverters.IsNull}}"/>

                            <!-- Unified skill detail (shows rating 0 for unpurchased skills) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding DetailSkill, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding DetailSkill.Name}"
                                           FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DetailSkill.SkillClass}"
                                               FontSize="10"
                                               Foreground="{StaticResource AccentCyberBrush}"/>
                                    <TextBlock Text="·" FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"/>
                                    <TextBlock Text="{Binding DetailSkill.AttributeDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"/>
                                </StackPanel>

                                <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,4"/>

                                <!-- Rating +/- -->
                                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                    <TextBlock Text="RATING" Classes="micro-label"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Classes="icon" Content="-"
                                                FontSize="12" FontWeight="Bold"
                                                Width="24" Height="24"
                                                Command="{Binding DecrementDetailRatingCommand}"/>
                                        <TextBlock Text="{Binding DetailSkill.RatingDisplay}"
                                                   Classes="stat-value"
                                                   Foreground="{StaticResource AccentCyberBrush}"
                                                   MinWidth="40" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Button Classes="icon" Content="+"
                                                FontSize="12" FontWeight="Bold"
                                                Width="24" Height="24"
                                                Command="{Binding IncrementDetailRatingCommand}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Add Skill button — visible when not yet purchased -->
                                <Button Content="Add Skill"
                                        Classes="primary action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding AddDetailSkillCommand}"
                                        IsVisible="{Binding !DetailSkill.IsPurchased}"/>

                                <!-- Specialization section — only shown once the skill is purchased -->
                                <StackPanel Spacing="10"
                                            IsVisible="{Binding DetailSkill.IsPurchased}">
                                    <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,4"/>
                                    <TextBlock Text="SPECIALIZATION" Classes="micro-label"/>

                                    <!-- Has spec: show name + rating + remove -->
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                                          IsVisible="{Binding DetailSkill.HasSpecialization}">
                                        <TextBlock Text="{Binding DetailSkill.SpecializationName}"
                                                   Classes="body"
                                                   Foreground="{StaticResource AccentManaBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DetailSkill.SpecializationRating}"
                                                   Classes="stat-value"
                                                   Foreground="{StaticResource AccentManaBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Classes="icon danger"
                                                Content="×" FontSize="12"
                                                Width="24" Height="24"
                                                Command="{Binding RemoveSelectedSpecializationCommand}"
                                                ToolTip.Tip="Remove specialization"/>
                                    </Grid>

                                    <!-- Needs higher rating hint -->
                                    <StackPanel Spacing="2"
                                                IsVisible="{Binding DetailSkill.NeedsHigherRatingToSpecialize}">
                                        <TextBlock Text="{Binding SpecializationRule.Title}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource WarningBrush}"/>
                                        <TextBlock Text="{Binding SpecializationRule.Body}"
                                                   FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{StaticResource InkSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Can specialize: show picker -->
                                    <StackPanel Spacing="8"
                                                IsVisible="{Binding DetailSkill.CanSpecializeNow}">
                                        <ComboBox ItemsSource="{Binding DetailSkill.AvailableSpecializations}"
                                                  SelectedItem="{Binding SelectedSpecTemplate}"
                                                  HorizontalAlignment="Stretch"
                                                  PlaceholderText="Pick a specialization">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="vm:AvailableSpecItem">
                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBox Text="{Binding CustomSpecName}"
                                                 Watermark="{Binding SelectedSpecTemplate.InputPlaceholder}"
                                                 IsVisible="{Binding SelectedSpecTemplate.RequiresUserInput, FallbackValue=False}"/>
                                        <Button Content="Add Specialization"
                                                Classes="action"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding AddSelectedSpecializationCommand}"/>
                                    </StackPanel>

                                    <!-- No specs available -->
                                    <TextBlock Text="No specializations available for this skill."
                                               FontSize="10" TextWrapping="Wrap"
                                               Foreground="{StaticResource InkMutedBrush}">
                                        <TextBlock.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="!DetailSkill.HasSpecialization"/>
                                                <Binding Path="!DetailSkill.HasAvailableSpecs"/>
                                            </MultiBinding>
                                        </TextBlock.IsVisible>
                                    </TextBlock>

                                    <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,4"/>

                                    <Button Content="Remove Skill"
                                            Classes="action"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding RemoveDetailSkillCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Available -->
            <Border Grid.Column="2" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionAvailable}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox Name="AvailableList"
                             ItemsSource="{Binding FilteredSkills}"
                             SelectedItem="{Binding SelectedAvailableSkill}"
                             DoubleTapped="OnAvailableListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:AvailableSkillItem">
                                <Grid ColumnDefinitions="*,40,40">
                                    <TextBlock Text="{Binding Name}"
                                               Classes="body" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Opacity="{Binding IsPurchased, Converter={StaticResource BoolToOpacityConverter}}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Specializations.Count, StringFormat='{}{0} spec'}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding HasSpecializations}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AttributeDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Purchased -->
            <Border Grid.Column="4" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionPurchased}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox Name="PurchasedList"
                             ItemsSource="{Binding PurchasedSkills}"
                             SelectedItem="{Binding SelectedPurchasedSkill}"
                             DoubleTapped="OnPurchasedListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:PurchasedSkillItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Classes="body" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SpecializationName}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource AccentManaBrush}"
                                                   IsVisible="{Binding HasSpecialization}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding RatingDisplay}"
                                               Classes="stat-value"
                                               Foreground="{StaticResource AccentCyberBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
