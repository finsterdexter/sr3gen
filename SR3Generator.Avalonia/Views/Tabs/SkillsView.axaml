<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.SkillsView"
             x:DataType="vm:SkillsViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.kind-active">
            <Setter Property="Foreground" Value="{StaticResource AccentCyberBrush}"/>
        </Style>
        <Style Selector="TextBlock.kind-knowledge">
            <Setter Property="Foreground" Value="{StaticResource AccentManaBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.SkillsTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.SkillsSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelCategory}" Classes="micro-label"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              MinWidth="200">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:SkillCategory">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Classes.kind-active="{Binding IsActive}"
                                               Classes.kind-knowledge="{Binding IsKnowledge}"/>
                                    <TextBlock Text="{Binding Count, StringFormat='({0})'}"
                                               Foreground="{StaticResource InkMutedBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderSubtleBrush}" Margin="16,4"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelActive}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value">
                        <Run Text="{Binding ActivePointsRemaining}"
                             Foreground="{StaticResource AccentCyberBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding ActivePointsAllowance}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="{x:Static res:Strings.LabelKnowledge}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value">
                        <Run Text="{Binding KnowledgePointsRemaining}"
                             Foreground="{StaticResource AccentManaBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding KnowledgePointsAllowance}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dual list: Available | Purchased -->
        <Grid Grid.Row="2" ColumnDefinitions="*,12,*">
            <!-- Available Skills -->
            <Border Grid.Column="0" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="12,12,12,8">
                        <TextBlock Text="{x:Static res:Strings.SectionAvailable}" Classes="section-header"/>
                        <TextBox Text="{Binding FilterText}" Watermark="{x:Static res:Strings.WatermarkSearchSkills}"/>
                    </StackPanel>

                    <ScrollViewer Padding="8,0,8,8">
                        <ItemsControl ItemsSource="{Binding FilteredSkills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AvailableSkillItem">
                                    <StackPanel>
                                        <Border Classes="list-row"
                                                Cursor="Hand"
                                                PointerPressed="OnAvailableSkillPressed">
                                            <Grid ColumnDefinitions="20,*,50">
                                                <Button Grid.Column="0"
                                                        Classes="icon"
                                                        Command="{Binding ToggleExpandCommand}"
                                                        IsVisible="{Binding HasSpecializations}"
                                                        Width="20" Height="20">
                                                    <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                                               FontSize="10"/>
                                                </Button>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Classes="body"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Opacity="{Binding IsPurchased, Converter={StaticResource BoolToOpacityConverter}}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding AttributeDisplay}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource InkMutedBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding Specializations}"
                                                      IsVisible="{Binding IsExpanded}"
                                                      Margin="20,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:AvailableSpecItem">
                                                    <Border Classes="list-row-sub">
                                                        <Grid ColumnDefinitions="*,40">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Classes="body-sm"
                                                                       Foreground="{StaticResource InkSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{x:Static res:Strings.BadgeSpec}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource InkMutedBrush}"
                                                                       HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Purchased Skills -->
            <Border Grid.Column="2" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionPurchased}"
                               Classes="section-header" Margin="12,12,12,8"/>

                    <ScrollViewer Padding="8,0,8,8">
                        <ItemsControl ItemsSource="{Binding PurchasedSkills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PurchasedSkillItem">
                                    <StackPanel>
                                        <Border Classes="list-row">
                                            <Grid ColumnDefinitions="20,64,*,40,24">
                                                <Button Grid.Column="0"
                                                        Classes="icon"
                                                        Command="{Binding ToggleExpandCommand}"
                                                        IsVisible="{Binding HasAvailableSpecs}"
                                                        Width="20" Height="20">
                                                    <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                                               FontSize="10"/>
                                                </Button>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            Spacing="2" VerticalAlignment="Center">
                                                    <Button Classes="icon" Command="{Binding DecrementCommand}"
                                                            Content="-" FontSize="12" FontWeight="Bold"
                                                            Width="20" Height="20"/>
                                                    <TextBlock Text="{Binding Rating}"
                                                               Classes="stat-value"
                                                               Foreground="{StaticResource AccentCyberBrush}"
                                                               Width="20" TextAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <Button Classes="icon" Command="{Binding IncrementCommand}"
                                                            Content="+" FontSize="12" FontWeight="Bold"
                                                            Width="20" Height="20"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Name}" Classes="body"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                                IsVisible="{Binding HasSpecialization}">
                                                        <TextBlock Text="{Binding SpecializationName}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource AccentManaBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding SpecializationRating}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentManaBrush}"/>
                                                        <Button Classes="icon"
                                                                Command="{Binding RemoveSpecCommand}"
                                                                Content="×" FontSize="10"
                                                                Width="16" Height="16"
                                                                HorizontalContentAlignment="Center"
                                                                VerticalContentAlignment="Center"
                                                                ToolTip.Tip="Remove specialization"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Grid.Column="3" Text="{Binding AttributeDisplay}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource InkMutedBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="4" Classes="icon danger"
                                                        Command="{Binding RemoveCommand}"
                                                        Content="×" FontSize="12"
                                                        Width="20" Height="20"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        ToolTip.Tip="Remove skill"/>
                                            </Grid>
                                        </Border>

                                        <!-- Rating-too-low hint (from rules_glossary: skill.specialization) -->
                                        <Border Classes="list-row-sub"
                                                Margin="20,0,0,0"
                                                Padding="8,6">
                                            <Border.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding Path="IsExpanded"/>
                                                    <Binding Path="NeedsHigherRatingToSpecialize"/>
                                                </MultiBinding>
                                            </Border.IsVisible>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding $parent[UserControl].((vm:SkillsViewModel)DataContext).SpecializationRule.Title}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource WarningBrush}"/>
                                                <TextBlock Text="{Binding $parent[UserControl].((vm:SkillsViewModel)DataContext).SpecializationRule.Body}"
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding AvailableSpecializations}"
                                                      Margin="20,0,0,0">
                                            <ItemsControl.IsVisible>
                                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                    <Binding Path="IsExpanded"/>
                                                    <Binding Path="CanSpecializeNow"/>
                                                </MultiBinding>
                                            </ItemsControl.IsVisible>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:AvailableSpecItem">
                                                    <Border Classes="list-row-sub">
                                                        <Panel>
                                                            <Grid ColumnDefinitions="*,40"
                                                                  IsVisible="{Binding !RequiresUserInput}"
                                                                  Cursor="Hand"
                                                                  PointerPressed="OnPurchasedSpecPressed">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="+"
                                                                               Foreground="{StaticResource AccentKarmaBrush}"
                                                                               FontWeight="Bold"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Classes="body-sm"
                                                                               Foreground="{StaticResource InkSecondaryBrush}"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1" Text="{x:Static res:Strings.BadgeFree}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource AccentKarmaBrush}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                                  IsVisible="{Binding RequiresUserInput}">
                                                                <TextBlock Text="{Binding DisplayName, StringFormat='{}{0}:'}"
                                                                           Classes="body-sm"
                                                                           Foreground="{StaticResource InkMutedBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0"/>
                                                                <TextBox Grid.Column="1"
                                                                         Watermark="{Binding InputPlaceholder}"
                                                                         FontSize="10"
                                                                         MinHeight="24"
                                                                         Padding="8,4"
                                                                         KeyDown="OnSpecNameKeyDown"/>
                                                                <Button Grid.Column="2"
                                                                        Content="+"
                                                                        FontSize="11" FontWeight="Bold"
                                                                        Width="24" Height="24"
                                                                        Padding="0"
                                                                        Margin="4,0,0,0"
                                                                        Click="OnAddCustomSpecClick"
                                                                        ToolTip.Tip="Add specialization"/>
                                                            </Grid>
                                                        </Panel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
