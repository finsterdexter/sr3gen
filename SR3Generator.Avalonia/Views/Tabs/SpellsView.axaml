<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.SpellsView"
             x:DataType="vm:SpellsViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,8">
            <TextBlock Text="Spells" Classes="page-title"/>
            <TextBlock Text="Purchase spells with spell points. Only for characters with Sorcery."
                       FontSize="11" Foreground="{StaticResource InkSecondaryBrush}"/>
        </StackPanel>

        <!-- No Magic Warning -->
        <Border Grid.Row="1" Background="#15ef4444" BorderBrush="#30ef4444" BorderThickness="1"
                CornerRadius="2" Padding="10" Margin="0,0,0,8"
                IsVisible="{Binding !HasSorcery}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="!" FontWeight="Bold" FontSize="11"
                           Foreground="{StaticResource DestructiveBrush}"/>
                <TextBlock Text="Cannot cast spells. Select a magical aspect with Sorcery."
                           FontSize="11" Foreground="{StaticResource DestructiveBrush}"/>
            </StackPanel>
        </Border>

        <!-- Spell Points Summary -->
        <Border Grid.Row="1" Classes="panel" Padding="8" Margin="0,0,0,8"
                IsVisible="{Binding HasSorcery}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="SPELL POINTS" Classes="section-header" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" FontFamily="JetBrains Mono, monospace" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Run Text="{Binding SpellPointsRemaining}" FontWeight="Bold"
                         Foreground="{StaticResource AccentManaBrush}"/>
                    <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                    <Run Text="{Binding SpellPointsAllowance}" Foreground="{StaticResource InkSecondaryBrush}"/>
                </TextBlock>
                <Button Grid.Column="2" Content="Buy Point (25k¥)" Command="{Binding BuySpellPointsCommand}"
                        Classes="compact"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,*" IsVisible="{Binding HasSorcery}">
            <!-- Available Spells -->
            <Border Grid.Column="0" Classes="panel" Margin="0,0,6,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                        <TextBlock Text="AVAILABLE SPELLS" Classes="section-header"/>
                        <ComboBox ItemsSource="{Binding AvailableCategories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <TreeView ItemsSource="{Binding SpellCategories}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Spells}">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="10"/>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.Styles>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Add Controls -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" Margin="6,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Force" FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                    <NumericUpDown Value="{Binding NewSpellForce}" Minimum="1" Maximum="6" Width="60"/>
                </StackPanel>
                <CheckBox Content="Exclusive" IsChecked="{Binding NewSpellExclusive}" FontSize="10"/>
                <TextBlock Text="(-2 cost)" FontSize="9" Foreground="{StaticResource InkMutedBrush}"
                           Margin="16,0,0,0"/>
                <Button Content="Add" HorizontalAlignment="Stretch" Classes="compact"/>
                <Button Content="Remove" Command="{Binding RemoveSpellCommand}" HorizontalAlignment="Stretch" Classes="compact"/>
            </StackPanel>

            <!-- Purchased Spells -->
            <Border Grid.Column="2" Classes="panel" Margin="6,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PURCHASED" Classes="section-header" Margin="0,0,0,4"/>
                    <ListBox ItemsSource="{Binding PurchasedSpells}"
                             SelectedItem="{Binding SelectedPurchasedSpell}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,50,30,40">
                                    <TextBlock Text="{Binding Name}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TypeDisplay}"
                                               FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Force, StringFormat='F{0}'}"
                                               FontWeight="Bold" FontFamily="JetBrains Mono, monospace"
                                               FontSize="10" Foreground="{StaticResource AccentManaBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CostDisplay}"
                                               FontSize="9" Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Reference -->
        <Border Grid.Row="3" Classes="panel-inset" Margin="0,8,0,0" IsVisible="{Binding HasSorcery}">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Cost = Force (1-6)" FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                <TextBlock Text="Exclusive: -2 cost (min 1)" FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
                <TextBlock Text="Buy points: 25,000¥ each" FontSize="9" Foreground="{StaticResource InkMutedBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
