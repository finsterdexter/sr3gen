<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="SR3Generator.Avalonia.Views.Tabs.SpiritsView"
             x:DataType="vm:SpiritsViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="{x:Static res:Strings.SpiritsTitle}" Classes="page-title"/>
            <TextBlock Classes="page-subtitle"
                       Text="{x:Static res:Strings.SpiritsSubtitle}"/>
        </StackPanel>

        <!-- Resource bar -->
        <Border Grid.Row="1" Classes="resource-bar" Margin="0,0,0,12"
                IsVisible="{Binding HasConjuring}">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelSpellPoints}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value-lg">
                        <Run Text="{Binding SpellPointsRemaining}"
                             Foreground="{StaticResource AccentManaBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding SpellPointsAllowance}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.LabelSpirits}" Classes="micro-label"/>
                    <TextBlock Classes="stat-value">
                        <Run Text="{Binding BoundSpirits.Count}"
                             Foreground="{StaticResource AccentKarmaBrush}"/>
                        <Run Text=" / " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="{Binding MaxSpirits}"
                             Foreground="{StaticResource InkSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- No-conjuring warning -->
        <Border Grid.Row="1" Background="#15ef4444" BorderBrush="#30ef4444"
                BorderThickness="1" CornerRadius="4"
                Padding="12,12" Margin="0,0,0,12"
                IsVisible="{Binding !HasConjuring}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="!" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource DestructiveBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static res:Strings.SpiritsNoConjuringWarning}"
                           Classes="body"
                           Foreground="{StaticResource DestructiveBrush}"/>
            </StackPanel>
        </Border>

        <!-- Detail 20% | Available 50% | Bound 30% -->
        <Grid Grid.Row="2" ColumnDefinitions="2*,12,5*,12,3*"
              IsVisible="{Binding HasConjuring}">
            <!-- Detail -->
            <Border Grid.Column="0" Classes="panel">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="DETAIL" Classes="section-header"/>
                    <ScrollViewer>
                        <Grid>
                            <TextBlock Text="Select a spirit type or bound spirit to see details."
                                       Classes="body" TextWrapping="Wrap"
                                       Foreground="{StaticResource InkMutedBrush}">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="SelectedSpiritType" Converter="{x:Static StringConverters.IsNullOrEmpty}"/>
                                        <Binding Path="SelectedBoundSpirit" Converter="{x:Static ObjectConverters.IsNull}"/>
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>

                            <!-- Bound spirit detail (with Remove) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding SelectedBoundSpirit, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding SelectedBoundSpirit.Name}"
                                           FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedBoundSpirit.TypeDisplay}"
                                           FontSize="10"
                                           Foreground="{StaticResource AccentManaBrush}"/>
                                <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                                      RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.LabelForce}" Classes="micro-label"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedBoundSpirit.Force, StringFormat='F{0}'}"
                                               Classes="stat-value"
                                               Foreground="{StaticResource AccentManaBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.LabelServices}" Classes="micro-label"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedBoundSpirit.Services}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.LabelCost}" Classes="micro-label"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedBoundSpirit.CostDisplay}"
                                               Classes="data" FontSize="11"
                                               Foreground="{StaticResource AccentNuyenBrush}"/>
                                </Grid>
                                <Button Content="{x:Static res:Strings.ButtonRemove}"
                                        Classes="action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding RemoveSpiritCommand}"
                                        Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Spirit-type detail (with configurator + Bind) -->
                            <StackPanel Spacing="10"
                                        IsVisible="{Binding SelectedSpiritType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding SelectedSpiritType}"
                                           FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static res:Strings.LabelForce}" Classes="micro-label"/>
                                    <NumericUpDown Value="{Binding NewSpiritForce}"
                                                   Minimum="1" Maximum="6"
                                                   Classes="prominent"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Static res:Strings.LabelServices}" Classes="micro-label"/>
                                    <NumericUpDown Value="{Binding NewSpiritServices}"
                                                   Minimum="1" Maximum="6"
                                                   Classes="prominent"
                                                   HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <TextBox Text="{Binding NewSpiritName}"
                                         Watermark="{x:Static res:Strings.WatermarkSpiritName}"/>

                                <Border Classes="panel-inset" Padding="8,6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{x:Static res:Strings.LabelCost}" Classes="micro-label"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PendingCostDisplay}"
                                                   Classes="stat-value"
                                                   Foreground="{StaticResource AccentManaBrush}">
                                            <ToolTip.Tip>
                                                <StackPanel MaxWidth="320" Spacing="4">
                                                    <TextBlock Text="{Binding StartingSpiritsRule.Title}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding StartingSpiritsRule.Body}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding StartingSpiritsRule.CostNote}" TextWrapping="Wrap"
                                                               Foreground="{StaticResource InkSecondaryBrush}"/>
                                                </StackPanel>
                                            </ToolTip.Tip>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <Button Content="{x:Static res:Strings.SpiritsAddButton}"
                                        Classes="primary action"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding AddSpiritCommand}"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Available spirit types -->
            <Border Grid.Column="2" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="{x:Static res:Strings.LabelSpiritType}"
                               Classes="section-header"
                               Margin="12,12,12,8"/>
                    <ListBox Name="AvailableList"
                             ItemsSource="{Binding AvailableSpiritTypes}"
                             SelectedItem="{Binding SelectedSpiritType}"
                             DoubleTapped="OnAvailableListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Classes="body"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Bound spirits -->
            <Border Grid.Column="4" Classes="panel" Padding="0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.SectionOwned}"
                               Classes="section-header" Margin="12,12,12,8"/>
                    <ListBox Name="BoundList"
                             ItemsSource="{Binding BoundSpirits}"
                             SelectedItem="{Binding SelectedBoundSpirit}"
                             DoubleTapped="OnBoundListDoubleTapped"
                             Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:BondedSpiritItem">
                                <Grid ColumnDefinitions="*,40,40,60">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Classes="body" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding TypeDisplay}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource AccentManaBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Force, StringFormat='F{0}'}"
                                               Classes="stat-value"
                                               Foreground="{StaticResource AccentManaBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Services, StringFormat='S{0}'}"
                                               Classes="stat-value"
                                               Foreground="{StaticResource InkSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CostDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
