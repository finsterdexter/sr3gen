<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             xmlns:res="using:SR3Generator.Avalonia.Resources"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="SR3Generator.Avalonia.Views.Tabs.SummaryView"
             x:DataType="vm:SummaryViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.summary-label">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource InkSecondaryBrush}"/>
            <Setter Property="Width" Value="60"/>
        </Style>
        <Style Selector="TextBlock.summary-value">
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Code, monospace"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12">
            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Static res:Strings.SummaryTitle}" Classes="page-title"/>
                <TextBlock Classes="page-subtitle"
                           Text="{x:Static res:Strings.SummarySubtitle}"/>
            </StackPanel>

            <!-- Validation / Finalize bar -->
            <Border Classes="resource-bar">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Text="{x:Static res:Strings.LabelStatus}" Classes="micro-label"/>
                    <TextBlock Grid.Column="1" Text="{Binding ValidationStatus}"
                               Classes="body" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Grid.Column="2" Content="{x:Static res:Strings.ButtonBuildCharacter}"
                            Command="{Binding BuildCharacterCommand}"
                            IsEnabled="{Binding IsValid}"
                            Classes="primary action"/>
                </Grid>
            </Border>

            <!-- Validation Issues (errors red, warnings amber) -->
            <ItemsControl ItemsSource="{Binding ValidationIssues}" IsVisible="{Binding HasIssues}">
                <ItemsControl.Styles>
                    <Style Selector="Border.issue-error">
                        <Setter Property="Background" Value="#15ef4444"/>
                        <Setter Property="BorderBrush" Value="#30ef4444"/>
                    </Style>
                    <Style Selector="Border.issue-warning">
                        <Setter Property="Background" Value="#15f59e0b"/>
                        <Setter Property="BorderBrush" Value="#30f59e0b"/>
                    </Style>
                    <Style Selector="Border.issue-error TextBlock.severity">
                        <Setter Property="Foreground" Value="{StaticResource DestructiveBrush}"/>
                    </Style>
                    <Style Selector="Border.issue-warning TextBlock.severity">
                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ValidationIssueItem">
                        <Border Classes.issue-error="{Binding IsError}"
                                Classes.issue-warning="{Binding IsWarning}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="10,6" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Classes="severity" Text="{Binding Severity}"
                                           FontWeight="Bold" FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Message}" Classes="body" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Two-column summary -->
            <Grid ColumnDefinitions="*,12,*">
                <!-- Left -->
                <StackPanel Grid.Column="0" Spacing="12">
                    <!-- Identity -->
                    <Border Classes="panel">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Static res:Strings.SectionIdentity}" Classes="section-header"/>
                            <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.LabelRace}" Classes="body"
                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RaceName}"
                                           Classes="body" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.LabelAspect}" Classes="body"
                                           Foreground="{StaticResource InkSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MagicAspect}"
                                           Classes="body" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentManaBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Attributes -->
                    <Border Classes="panel">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Static res:Strings.SectionAttributes}" Classes="section-header"/>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="4" ColumnSpacing="16">
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrBody}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Body}" Classes="summary-value"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrQuickness}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Quickness}" Classes="summary-value"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrStrength}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Strength}" Classes="summary-value"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrCharisma}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Charisma}" Classes="summary-value"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrIntelligence}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Intelligence}" Classes="summary-value"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrWillpower}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Willpower}" Classes="summary-value"/>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,2"/>

                            <Grid ColumnDefinitions="*,*,*">
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrReaction}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Reaction}" Classes="summary-value"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrEssence}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding EssenceDisplay}" Classes="summary-value"
                                               Foreground="{StaticResource AccentCyberBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Text="{x:Static res:Strings.AbbrMagic}" Classes="summary-label"/>
                                    <TextBlock Text="{Binding Magic}" Classes="summary-value"
                                               Foreground="{StaticResource AccentManaBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Active Skills -->
                    <Border Classes="panel">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.SectionActiveSkills}" Classes="section-header"/>
                            <ItemsControl ItemsSource="{Binding ActiveSkillsSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Classes="body"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Static res:Strings.SummaryEmptyValue}" Classes="body"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       IsVisible="{Binding !ActiveSkillsSummary.Count}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right -->
                <StackPanel Grid.Column="2" Spacing="12">
                    <!-- Resources -->
                    <Border Classes="panel">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{x:Static res:Strings.SectionResources}" Classes="section-header"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.SummaryRemainingNuyen}" Classes="body"
                                           Foreground="{StaticResource InkSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding NuyenRemaining, StringFormat='{}{0:N0}¥'}"
                                           Classes="stat-value-lg"
                                           Foreground="{StaticResource AccentNuyenBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Spells -->
                    <Border Classes="panel">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.SectionSpells}" Classes="section-header"/>
                            <ItemsControl ItemsSource="{Binding SpellsSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Classes="body"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Static res:Strings.SummaryEmptyValue}" Classes="body"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       IsVisible="{Binding !SpellsSummary.Count}"/>
                        </StackPanel>
                    </Border>

                    <!-- Gear -->
                    <Border Classes="panel">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.SectionGear}" Classes="section-header"/>
                            <ItemsControl ItemsSource="{Binding GearSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Classes="body"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Static res:Strings.SummaryEmptyValue}" Classes="body"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       IsVisible="{Binding !GearSummary.Count}"/>
                        </StackPanel>
                    </Border>

                    <!-- Contacts -->
                    <Border Classes="panel">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Static res:Strings.SectionContacts}" Classes="section-header"/>
                            <ItemsControl ItemsSource="{Binding ContactsSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Classes="body"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Static res:Strings.SummaryEmptyValue}" Classes="body"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       IsVisible="{Binding !ContactsSummary.Count}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
