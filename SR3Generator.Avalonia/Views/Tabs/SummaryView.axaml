<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SR3Generator.Avalonia.ViewModels.Tabs"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
             x:Class="SR3Generator.Avalonia.Views.Tabs.SummaryView"
             x:DataType="vm:SummaryViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">
            <TextBlock Text="Character Summary" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Review your character and finalize creation."
                       TextWrapping="Wrap" Foreground="Gray"/>

            <!-- Validation Status -->
            <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding ValidationStatus}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Build Character"
                            Command="{Binding BuildCharacterCommand}"
                            IsEnabled="{Binding IsValid}"/>
                </Grid>
            </Border>

            <!-- Validation Issues -->
            <ItemsControl ItemsSource="{Binding ValidationIssues}"
                          IsVisible="{Binding !IsValid}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#20FF0000" CornerRadius="4" Padding="8" Margin="0,2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Severity}" FontWeight="Bold" Foreground="Red"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Two Column Layout -->
            <Grid ColumnDefinitions="*,16,*">
                <!-- Left Column -->
                <StackPanel Grid.Column="0" Spacing="16">
                    <!-- Basic Info -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Basic Info" FontWeight="SemiBold" FontSize="16"/>
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Race:" Foreground="Gray"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RaceName}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Magic:" Foreground="Gray"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MagicAspect}" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Attributes -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Attributes" FontWeight="SemiBold" FontSize="16"/>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                <!-- Physical -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Body: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Body}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Quickness: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Quickness}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Strength: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Strength}" FontWeight="Bold"/>
                                </StackPanel>

                                <!-- Mental -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="Charisma: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Charisma}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="Intelligence: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Intelligence}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="Willpower: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Willpower}" FontWeight="Bold"/>
                                </StackPanel>

                                <!-- Derived -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Reaction: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Reaction}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Essence: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Essence}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Magic: " Foreground="Gray" Width="80"/>
                                    <TextBlock Text="{Binding Magic}" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Active Skills -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Active Skills" FontWeight="SemiBold" FontSize="16"/>
                            <ItemsControl ItemsSource="{Binding ActiveSkillsSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Spacing="16">
                    <!-- Spells -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Spells" FontWeight="SemiBold" FontSize="16"/>
                            <ItemsControl ItemsSource="{Binding SpellsSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="(None)" Foreground="Gray" FontSize="12"
                                       IsVisible="{Binding !SpellsSummary.Count}"/>
                        </StackPanel>
                    </Border>

                    <!-- Gear -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Gear" FontWeight="SemiBold" FontSize="16"/>
                            <ItemsControl ItemsSource="{Binding GearSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="(None)" Foreground="Gray" FontSize="12"
                                       IsVisible="{Binding !GearSummary.Count}"/>
                        </StackPanel>
                    </Border>

                    <!-- Contacts -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Contacts" FontWeight="SemiBold" FontSize="16"/>
                            <ItemsControl ItemsSource="{Binding ContactsSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="(None)" Foreground="Gray" FontSize="12"
                                       IsVisible="{Binding !ContactsSummary.Count}"/>
                        </StackPanel>
                    </Border>

                    <!-- Resources -->
                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Resources" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{Binding NuyenRemaining, StringFormat='Remaining Nuyen: {0:N0}¥'}"
                                       FontSize="14"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
